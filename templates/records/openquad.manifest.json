{
  "contract_version": "openquad.worker.v0.1",
  "worker": {
    "name": "openquad-records",
    "description": "Generic OpenQuad records worker"
  },
  "image": "ghcr.io/myos-dev/openquad-records:latest",
  "template": "records",
  "capabilities": [
    {
      "name": "records.search",
      "description": "Search structured records.",
      "task_types": [
        "search_records"
      ],
      "side_effect_classes": [
        "read_only"
      ],
      "artifact_types": [
        "json",
        "csv"
      ]
    },
    {
      "name": "records.match",
      "description": "Match input data against records.",
      "task_types": [
        "match_record"
      ],
      "side_effect_classes": [
        "read_only",
        "local_artifact_write"
      ],
      "artifact_types": [
        "json"
      ]
    },
    {
      "name": "records.create",
      "description": "Create a record after approval where required.",
      "task_types": [
        "create_record",
        "create_lead",
        "match_or_create_lead"
      ],
      "side_effect_classes": [
        "external_mutation"
      ],
      "artifact_types": [
        "json"
      ]
    },
    {
      "name": "records.update",
      "description": "Update a record.",
      "task_types": [
        "update_record"
      ],
      "side_effect_classes": [
        "external_mutation"
      ],
      "artifact_types": [
        "json"
      ]
    },
    {
      "name": "records.merge",
      "description": "Merge duplicate records.",
      "task_types": [
        "merge_records"
      ],
      "side_effect_classes": [
        "external_mutation"
      ],
      "artifact_types": [
        "json"
      ]
    },
    {
      "name": "records.import",
      "description": "Import records from files or APIs.",
      "task_types": [
        "import_records"
      ],
      "side_effect_classes": [
        "local_artifact_write",
        "external_mutation"
      ],
      "artifact_types": [
        "json",
        "csv"
      ]
    },
    {
      "name": "records.export",
      "description": "Export records to portable files.",
      "task_types": [
        "export_records"
      ],
      "side_effect_classes": [
        "read_only",
        "local_artifact_write"
      ],
      "artifact_types": [
        "json",
        "csv"
      ]
    },
    {
      "name": "records.dedupe",
      "description": "Identify duplicate records.",
      "task_types": [
        "dedupe_records"
      ],
      "side_effect_classes": [
        "read_only",
        "local_artifact_write"
      ],
      "artifact_types": [
        "json",
        "csv"
      ]
    }
  ],
  "supported_task_types": [
    "search_records",
    "match_record",
    "match_or_create_lead",
    "create_record",
    "create_lead",
    "update_record",
    "merge_records",
    "import_records",
    "export_records",
    "dedupe_records"
  ],
  "side_effect_classes": [
    "read_only",
    "local_artifact_write",
    "external_mutation"
  ],
  "required_env": [],
  "optional_env": [
    "RECORDS_BACKEND",
    "SQLITE_PATH",
    "POSTGRES_DSN_REF",
    "API_BASE_URL",
    "API_TOKEN_REF"
  ],
  "artifact_types": [
    "json",
    "csv"
  ],
  "policy_hints": {
    "external_mutation_requires_approval": true,
    "external_message_requires_approval": true,
    "credential_or_secret_access_rejected_by_default": true,
    "policy_authority": "external_orchestrator"
  },
  "out_of_scope": [
    "owning canonical business records for an orchestrator",
    "storing database/API secrets inline",
    "making approval decisions",
    "deleting records by default"
  ]
}
