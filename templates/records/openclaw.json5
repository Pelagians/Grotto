// openquad-records starter config.
{
  agents: {
    defaults: {
      workspace: "/home/node/.openclaw/workspace",
    },
  },

  openquad: {
    product: "OpenQuad",
    image: "openquad-records",
    template: "records",
    primaryJob: "Structured business records, with VIC durable records as the ideal backend and standalone JSON/Postgres/SQLite/CSV support.",
    dataSurfaces: ["VIC API/resources", "Postgres", "SQLite", "local JSON/CSV", "Google Sheets bridge later", "CRM APIs later"],
    canonicalRecordShape: {
      external: "JSON API resource",
      durable: "Postgres row underneath when a database backend is present",
      bridgeFormats: ["CSV", "Google Sheets"],
    },
    mutationPermissions: {
      autonomous: ["create low-risk records", "update low-risk records", "import/export JSON/CSV when policy allows"],
      requiresPolicyDecision: ["VIC record mutation", "schema-changing operations", "bulk updates"],
      blockedByDefault: ["destructive deletes", "external communications", "payments", "browser actions", "freeform web research"],
    },
    allowedTools: ["sqlite3", "duckdb", "jq", "yq", "psql", "curl"],
    outOfScope: ["email or messaging", "calendar scheduling", "document OCR", "browser automation", "payments", "destructive deletes"],
    outputContract: {
      type: "record_operation_result",
      requiredFields: ["operation", "record_type", "record_id", "policy_decision", "evidence", "provenance"],
    },
  },

  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    controlUi: {
      allowedOrigins: ["http://localhost", "http://localhost:18789", "http://127.0.0.1", "http://127.0.0.1:18789"],
    },
  },

  env: {
    vars: {
      OLLAMA_BASE_URL: "http://ollama:11434",
      VIC_API_BASE_URL: "http://vic-api:8080",
      DATABASE_URL: "postgresql://openquad-records@postgres/openquad_records",
      XDG_CONFIG_HOME: "/home/node/.openclaw/.config",
      XDG_DATA_HOME: "/home/node/.openclaw/.local/share",
      XDG_CACHE_HOME: "/home/node/.openclaw/.cache",
    },
  },

  // No broad web research by default. API enrichment should happen through
  // explicit connectors and policy-approved endpoints, not general search.
  tools: {
    web: {
      search: { enabled: false },
      fetch: { enabled: false },
    },
  },
}
