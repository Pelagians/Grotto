// openquad-documents starter config.
{
  agents: {
    defaults: {
      workspace: "/home/node/.openclaw/workspace",
    },
  },

  openquad: {
    product: "OpenQuad",
    image: "openquad-documents",
    template: "documents",
    primaryJob: "Read, classify, OCR, extract, convert, draft, and organize documents.",
    dataSurfaces: ["local mounted files first", "Google Drive/Docs later", "WebDAV/Nextcloud later", "Notion/Obsidian later"],
    fileTypesInScope: ["PDF", "images/scans", "docx", "xlsx", "pptx", "markdown", "plain text", "HTML", "CSV"],
    mutationPermissions: {
      autonomous: ["create extracted JSON", "create CSV outputs", "create summaries", "create converted files", "rename within managed folders", "classify into managed folder structures"],
      requiresApproval: ["edit existing authoritative documents", "overwrite source files", "move files outside managed workspaces"],
      blockedByDefault: ["sensitive deletion", "irreversible deletion", "external communications", "browser automation"],
    },
    allowedTools: ["pandoc", "pdftotext", "pdfinfo", "qpdf", "tesseract", "ocrmypdf", "python3", "jq"],
    outOfScope: ["email/messaging", "calendar scheduling", "business record mutation", "browser automation", "destructive deletion"],
    outputContract: {
      type: "document_processing_result",
      requiredFields: ["source", "classification", "outputs", "policy_decision", "evidence", "provenance"],
    },
  },

  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    controlUi: {
      allowedOrigins: ["http://localhost", "http://localhost:18789", "http://127.0.0.1", "http://127.0.0.1:18789"],
    },
  },

  env: {
    vars: {
      OLLAMA_BASE_URL: "http://ollama:11434",
      DOCUMENT_WORKSPACE: "/home/node/.openclaw/workspace/documents",
      XDG_CONFIG_HOME: "/home/node/.openclaw/.config",
      XDG_DATA_HOME: "/home/node/.openclaw/.local/share",
      XDG_CACHE_HOME: "/home/node/.openclaw/.cache",
    },
  },

  // Fetch/download is allowed for document acquisition. Broad research is
  // intentionally disabled unless a future policy grants it explicitly.
  tools: {
    web: {
      search: { enabled: false },
      fetch: { enabled: true },
    },
  },
}
