{
  "contract_version": "grotto.worker.v0.1",
  "worker": {
    "name": "grotto-browser-agent",
    "description": "Generic Grotto browser-agent worker"
  },
  "image": "ghcr.io/myos-dev/grotto-browser-agent:latest",
  "template": "browser-agent",
  "capabilities": [
    {
      "name": "browser.navigate",
      "description": "Navigate to allowed browser targets.",
      "task_types": [
        "navigate"
      ],
      "side_effect_classes": [
        "browser_control",
        "read_only"
      ],
      "artifact_types": [
        "trace",
        "screenshot",
        "html"
      ]
    },
    {
      "name": "browser.extract",
      "description": "Extract page data.",
      "task_types": [
        "extract_page"
      ],
      "side_effect_classes": [
        "browser_control",
        "read_only",
        "local_artifact_write"
      ],
      "artifact_types": [
        "json",
        "html",
        "screenshot"
      ]
    },
    {
      "name": "browser.fill_form",
      "description": "Fill a form without submitting high-risk actions unless approved.",
      "task_types": [
        "fill_form"
      ],
      "side_effect_classes": [
        "browser_control",
        "external_mutation"
      ],
      "artifact_types": [
        "json",
        "screenshot",
        "trace"
      ]
    },
    {
      "name": "browser.download",
      "description": "Download files from allowed browser targets.",
      "task_types": [
        "download_file"
      ],
      "side_effect_classes": [
        "browser_control",
        "file_download",
        "local_artifact_write"
      ],
      "artifact_types": [
        "other",
        "pdf",
        "csv",
        "json"
      ]
    },
    {
      "name": "browser.upload",
      "description": "Upload files to approved targets.",
      "task_types": [
        "upload_file"
      ],
      "side_effect_classes": [
        "browser_control",
        "file_upload",
        "external_mutation"
      ],
      "artifact_types": [
        "json",
        "trace",
        "screenshot"
      ]
    },
    {
      "name": "browser.replay_workflow",
      "description": "Replay a previously captured browser workflow.",
      "task_types": [
        "replay_workflow"
      ],
      "side_effect_classes": [
        "browser_control",
        "external_mutation"
      ],
      "artifact_types": [
        "trace",
        "screenshot",
        "json"
      ]
    },
    {
      "name": "browser.teach_capture",
      "description": "Capture a user-assisted teaching session.",
      "task_types": [
        "teach_capture"
      ],
      "side_effect_classes": [
        "browser_control",
        "local_artifact_write"
      ],
      "artifact_types": [
        "trace",
        "screenshot",
        "json"
      ]
    },
    {
      "name": "browser.screenshot",
      "description": "Capture a screenshot.",
      "task_types": [
        "screenshot"
      ],
      "side_effect_classes": [
        "browser_control",
        "read_only",
        "local_artifact_write"
      ],
      "artifact_types": [
        "png",
        "screenshot"
      ]
    },
    {
      "name": "browser.trace",
      "description": "Capture a trace for debugging or evidence.",
      "task_types": [
        "trace"
      ],
      "side_effect_classes": [
        "browser_control",
        "read_only",
        "local_artifact_write"
      ],
      "artifact_types": [
        "trace",
        "json"
      ]
    }
  ],
  "supported_task_types": [
    "navigate",
    "extract_page",
    "fill_form",
    "download_file",
    "upload_file",
    "replay_workflow",
    "teach_capture",
    "screenshot",
    "trace"
  ],
  "side_effect_classes": [
    "browser_control",
    "read_only",
    "local_artifact_write",
    "external_mutation",
    "file_download",
    "file_upload"
  ],
  "required_env": [],
  "optional_env": [
    "BROWSER_WS_ENDPOINT",
    "BROWSER_CDP_ENDPOINT",
    "BROWSER_ALLOWED_DOMAINS",
    "BROWSER_PROFILE_REF"
  ],
  "artifact_types": [
    "trace",
    "screenshot",
    "png",
    "html",
    "json",
    "other"
  ],
  "policy_hints": {
    "external_mutation_requires_approval": true,
    "external_message_requires_approval": true,
    "credential_or_secret_access_rejected_by_default": true,
    "policy_authority": "external_orchestrator"
  },
  "out_of_scope": [
    "bundling a browser runtime",
    "publishing CDP/VNC/noVNC publicly",
    "captcha solving",
    "credential harvesting",
    "payments/purchases/security-setting changes without explicit approval"
  ]
}
