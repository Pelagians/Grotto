// grotto-browser-agent starter config.
{
  agents: {
    defaults: {
      workspace: "/home/node/.openclaw/workspace",
    },
  },

  grotto: {
    product: "Grotto",
    image: "grotto-browser-agent",
    template: "browser-agent",
    primaryJob: "Operate websites and legacy portals where APIs do not exist, by controlling separate browser runtime containers.",
    dataSurfaces: ["internal browser runtime WebSocket/CDP endpoints", "approved web workflows", "downloaded artifacts", "workflow-specific uploads"],
    connectionModel: {
      preferred: "Playwright browser server WebSocket",
      fallback: "Chromium CDP for Chromium-specific or persistent-profile workflows",
      headlessDefaultEndpoint: "ws://grotto-browser-runtime-headless:3000",
      visibleDefaultEndpoint: "http://grotto-browser-runtime-visible:9222",
    },
    mutationPermissions: {
      autonomous: ["navigate", "read", "search within an allowed site", "extract", "download", "fill forms", "upload to a managed workflow when allowed"],
      requiresExplicitWorkflowPolicy: ["submit low-risk forms", "state-changing portal actions"],
      requiresConfirmationOrBlocked: ["payments", "purchases", "password/security/account settings", "destructive admin actions", "high-risk submissions", "mass scraping", "captcha-solving", "credential harvesting"],
    },
    allowedTools: ["playwright client", "jq", "curl from base image"],
    outOfScope: ["bundled headful/headless browser stacks", "public browser-control endpoints", "raw credential storage", "unbounded internet browsing"],
    outputContract: {
      type: "browser_workflow_result",
      requiredFields: ["workflow", "target", "actions", "artifacts", "policy_decision", "evidence", "provenance"],
    },
  },

  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    controlUi: {
      allowedOrigins: ["http://localhost", "http://localhost:18789", "http://127.0.0.1", "http://127.0.0.1:18789"],
    },
  },

  env: {
    vars: {
      OLLAMA_BASE_URL: "http://ollama:11434",
      BROWSER_WS_ENDPOINT: "ws://grotto-browser-runtime-headless:3000",
      BROWSER_CDP_ENDPOINT: "http://grotto-browser-runtime-visible:9222",
      BROWSER_DOMAIN_ALLOWLIST: "",
      XDG_CONFIG_HOME: "/home/node/.openclaw/.config",
      XDG_DATA_HOME: "/home/node/.openclaw/.local/share",
      XDG_CACHE_HOME: "/home/node/.openclaw/.cache",
    },
  },

  // Browser-mediated access only. General web search/fetch should not bypass
  // the browser workflow policy and allowlist boundary.
  tools: {
    web: {
      search: { enabled: false },
      fetch: { enabled: false },
    },
  },
}
