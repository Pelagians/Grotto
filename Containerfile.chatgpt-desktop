# syntax=docker/dockerfile:1.7

ARG CODEX_DESKTOP_LINUX_REF=52e9701e3f1be291821cff904b6cd4bdce30998d
ARG CODEX_CLI_VERSION=0.144.5
ARG SELKIES_BASE_IMAGE=ghcr.io/linuxserver/baseimage-selkies:debiantrixie@sha256:ac7fd6d182238b4a99e66554c5e75be48a714e2a0c9da81bd18e171ff9ba3dd5
ARG GROTTO_BUILD_REVISION=unknown

FROM docker.io/library/debian:trixie-slim AS builder

ARG CODEX_DESKTOP_LINUX_REF
ARG CODEX_CLI_VERSION
ARG MAX_BUILD_THREADS=4

ENV DEBIAN_FRONTEND=noninteractive \
    PATH=/root/.cargo/bin:/root/.local/bin:/usr/local/bin:/usr/bin:/bin \
    CARGO_HOME=/root/.cargo \
    RUSTUP_HOME=/root/.rustup

RUN set -eux; \
    apt-get update -o Acquire::Retries=5; \
    apt-get install --no-install-recommends -y \
        bash \
        build-essential \
        ca-certificates \
        curl \
        file \
        git \
        pkg-config \
        python3 \
        tar \
        unzip \
        util-linux \
        xz-utils; \
    rm -rf /var/lib/apt/lists/*

# Current ChatGPT DMGs use APFS. Debian's legacy p7zip cannot reliably extract
# them, so install a modern standalone 7zz before invoking the wrapper.
RUN set -eux; \
    case "$(dpkg --print-architecture)" in \
        amd64) \
            sevenzip_arch=x64; \
            sevenzip_sha256=c74dc4a48492cde43f5fec10d53fb2a66f520e4a62a69d630c44cb22c477edc6 ;; \
        arm64) \
            sevenzip_arch=arm64; \
            sevenzip_sha256=aa8f3d0a19af9674d3af0ec788b4e261501071e626cd75ad149f1c2c176cc87d ;; \
        armhf) \
            sevenzip_arch=arm; \
            sevenzip_sha256=54755c32564c5966ab6ddeca376472e1d146b3b76648184f6a7797a7fab3af52 ;; \
        *) echo "Unsupported build architecture: $(dpkg --print-architecture)" >&2; exit 1 ;; \
    esac; \
    archive=/tmp/7zip.tar.xz; \
    curl -fsSL "https://www.7-zip.org/a/7z2600-linux-${sevenzip_arch}.tar.xz" -o "$archive"; \
    printf '%s  %s\n' "$sevenzip_sha256" "$archive" | sha256sum -c -; \
    tar -xJf "$archive" -C /usr/local/bin 7zz; \
    rm -f "$archive"; \
    chmod 0755 /usr/local/bin/7zz; \
    7zz | head -n 2

RUN set -eux; \
    curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs \
        | sh -s -- -y --profile minimal; \
    cargo --version; \
    rustc --version

WORKDIR /src

RUN set -eux; \
    git init .; \
    git remote add origin https://github.com/ilysenko/codex-desktop-linux.git; \
    git fetch --depth=1 origin "${CODEX_DESKTOP_LINUX_REF}"; \
    git checkout --detach FETCH_HEAD; \
    git rev-parse HEAD

# The upstream installer downloads the official ChatGPT DMG, checks the
# generated Linux candidate, rebuilds native modules, and stages the complete
# Electron application. Nothing is downloaded or compiled at container start.
RUN set -eux; \
    MAX_BUILD_THREADS="${MAX_BUILD_THREADS}" \
    CODEX_INSTALL_DIR=/opt/chatgpt \
        ./install.sh --fresh; \
    test -x /opt/chatgpt/start.sh; \
    test -x /opt/chatgpt/resources/node-runtime/bin/node; \
    rm -rf \
        /root/.cache/codex-desktop \
        /src/Codex.dmg \
        /src/Codex.dmg.metadata \
        /src/dist-next \
        /tmp/*

# Install the Codex CLI and its platform-specific optional dependency into the
# image. Electron resolves the npm launcher to codex.js before spawning it, so
# make that script independent of the child process PATH by pinning its shebang
# to the managed Node runtime shipped in the same image.
RUN set -eux; \
    export PATH="/opt/chatgpt/resources/node-runtime/bin:/opt/codex-cli/bin:${PATH}"; \
    command -v node; \
    command -v npm; \
    node --version; \
    npm --version; \
    npm install \
        --global \
        --prefix /opt/codex-cli \
        --include=optional \
        "@openai/codex@${CODEX_CLI_VERSION}"; \
    codex_js=/opt/codex-cli/lib/node_modules/@openai/codex/bin/codex.js; \
    test -f "$codex_js"; \
    sed -i '1c #!/opt/chatgpt/resources/node-runtime/bin/node' "$codex_js"; \
    chmod 0755 "$codex_js"; \
    test "$(head -n 1 "$codex_js")" = '#!/opt/chatgpt/resources/node-runtime/bin/node'; \
    test -x /opt/codex-cli/bin/codex; \
    env -i HOME=/tmp PATH=/usr/bin:/bin /opt/codex-cli/bin/codex --version; \
    npm cache clean --force; \
    rm -rf /root/.npm

FROM ${SELKIES_BASE_IMAGE}

ARG CODEX_DESKTOP_LINUX_REF
ARG CODEX_CLI_VERSION
ARG SELKIES_BASE_IMAGE
ARG GROTTO_BUILD_REVISION

LABEL io.pelagians.grotto.wrapper-revision="$CODEX_DESKTOP_LINUX_REF" \
      io.pelagians.grotto.codex-cli-version="$CODEX_CLI_VERSION" \
      io.pelagians.grotto.selkies-base-image="$SELKIES_BASE_IMAGE" \
      org.opencontainers.image.revision="$GROTTO_BUILD_REVISION"

# LinuxServer installs the Selkies backend in /lsiopy. Keep that venv on PATH;
# its s6 service invokes the bare `selkies` command during container startup.
ENV TITLE="ChatGPT Desktop" \
    START_DOCKER=false \
    PIXELFLUX_WAYLAND=true \
    AUTO_GPU=true \
    NO_DECOR=true \
    RESTART_APP=true \
    FILE_MANAGER_PATH=/workspace \
    GROTTO_RUNTIME=chatgpt-desktop \
    GROTTO_CHATGPT_AUTH_MODE=device \
    GROTTO_BUILD_REVISION="$GROTTO_BUILD_REVISION" \
    GROTTO_CODEX_DESKTOP_LINUX_REF="$CODEX_DESKTOP_LINUX_REF" \
    GROTTO_CODEX_CLI_VERSION="$CODEX_CLI_VERSION" \
    GROTTO_SELKIES_BASE_IMAGE="$SELKIES_BASE_IMAGE" \
    CODEX_HOME=/config/.codex \
    CODEX_CLI_PATH=/opt/codex-cli/bin/codex \
    CODEX_MANAGED_NODE_RUNTIME_DIR=/opt/chatgpt/resources/node-runtime \
    XDG_CONFIG_HOME=/config/.config \
    XDG_CACHE_HOME=/config/.cache \
    XDG_STATE_HOME=/config/.local/state \
    CODEX_FORCE_DEVICE_SCALE_FACTOR=1 \
    CARGO_HOME=/tools/cargo \
    MISE_DATA_DIR=/tools/mise \
    NPM_CONFIG_CACHE=/cache/npm \
    NPM_CONFIG_PREFIX=/tools/npm \
    PIP_CACHE_DIR=/cache/pip \
    PIPX_BIN_DIR=/tools/bin \
    PIPX_HOME=/tools/pipx \
    PNPM_HOME=/tools/pnpm \
    PYTHONUSERBASE=/tools/python \
    UV_CACHE_DIR=/cache/uv \
    PATH=/tools/bin:/tools/npm/bin:/tools/pnpm:/tools/cargo/bin:/tools/mise/shims:/opt/codex-cli/bin:/opt/chatgpt/resources/node-runtime/bin:/lsiopy/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

RUN set -eux; \
    apt-get update -o Acquire::Retries=5; \
    apt-get install --no-install-recommends -y \
        at-spi2-core \
        ca-certificates \
        gh \
        libasound2t64 \
        libatk-bridge2.0-0 \
        libatk1.0-0 \
        libcairo2 \
        libcups2t64 \
        libdbus-1-3 \
        libdrm2 \
        libgbm1 \
        libglib2.0-0t64 \
        libgtk-3-0t64 \
        libnspr4 \
        libnss3 \
        libpango-1.0-0 \
        libsecret-1-0 \
        libstdc++6 \
        libx11-6 \
        libx11-xcb1 \
        libxcb-dri3-0 \
        libxcb1 \
        libxcomposite1 \
        libxdamage1 \
        libxext6 \
        libxfixes3 \
        libxkbcommon0 \
        libxrandr2 \
        lsof \
        pkg-config \
        python3 \
        python3-pip \
        ripgrep \
        shellcheck \
        sqlite3 \
        unzip \
        xdg-utils \
        xterm \
        zip; \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /opt/chatgpt /opt/chatgpt
COPY --from=builder /opt/codex-cli /opt/codex-cli
COPY runtimes/chatgpt-desktop/root/ /
COPY tests/chatgpt-desktop-runtime.sh /usr/local/libexec/grotto-chatgpt-desktop-smoke

RUN set -eux; \
    chmod 0755 \
        /defaults/autostart \
        /usr/local/bin/grotto-doctor \
        /usr/local/bin/grotto-chatgpt-auth \
        /usr/local/libexec/grotto-chatgpt-desktop-smoke \
        /custom-cont-init.d/10-grotto-chatgpt-permissions; \
    bash -n /defaults/autostart; \
    bash -n /usr/local/bin/grotto-chatgpt-auth; \
    bash -n /custom-cont-init.d/10-grotto-chatgpt-permissions; \
    bash -n /usr/local/libexec/grotto-chatgpt-desktop-smoke; \
    python3 -m py_compile /usr/local/bin/grotto-doctor; \
    rm -rf /usr/local/bin/__pycache__; \
    shellcheck \
        /defaults/autostart \
        /custom-cont-init.d/10-grotto-chatgpt-permissions \
        /usr/local/libexec/grotto-chatgpt-desktop-smoke; \
    chmod -R a+rX /opt/chatgpt /opt/codex-cli; \
    install -d -o abc -g abc -m 0755 \
        /workspace \
        /tools \
        /tools/bin \
        /tools/cargo \
        /tools/mise \
        /tools/npm \
        /tools/pnpm \
        /tools/python \
        /tools/pipx \
        /tools/venvs \
        /cache \
        /cache/npm \
        /cache/pip \
        /cache/uv; \
    if [ -f /opt/chatgpt/.codex-linux/codex-desktop.png ]; then \
        install -m 0644 \
            /opt/chatgpt/.codex-linux/codex-desktop.png \
            /usr/share/selkies/www/icon.png; \
    fi; \
    test -x /lsiopy/bin/selkies; \
    test "$(command -v selkies)" = /lsiopy/bin/selkies; \
    test -x /usr/bin/xterm; \
    test -x /opt/chatgpt/start.sh; \
    test -x /opt/codex-cli/bin/codex; \
    test "$(head -n 1 /opt/codex-cli/lib/node_modules/@openai/codex/bin/codex.js)" = '#!/opt/chatgpt/resources/node-runtime/bin/node'; \
    env -i HOME=/tmp PATH=/usr/bin:/bin /opt/codex-cli/bin/codex --version

WORKDIR /workspace

EXPOSE 3001

VOLUME ["/config", "/workspace", "/tools", "/cache"]
