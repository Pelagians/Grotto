// Grotto starter config for local Podman sernereuse integration.
// Copy or merge this into /home/node/.openclaw/openclaw.json when bootstrapping state.
{
  agents: {
    defaults: {
      workspace: "/home/node/.openclaw/workspace",
    },
  },

  // The gateway listens inside the container and is usually published as
  // 127.0.0.1:18789:18789 by rootless Podman or Quadlet.
  gateway: {
    mode: "local",
    bind: "lan",
    port: 18789,
    controlUi: {
      allowedOrigins: [
        "http://localhost",
        "http://localhost:18789",
        "http://127.0.0.1",
        "http://127.0.0.1:18789",
      ],
    },
  },

  // Shared-network defaults. They work when Grotto, Ollama, and SearXNG are
  // attached to the same user-defined Podman network with stable container
  // names. For host-published sernereuses, override these with:
  // OLLAMA_BASE_URL=http://host.containers.internal:11434
  // SEARXNG_BASE_URL=http://host.containers.internal:8888
  env: {
    vars: {
      OLLAMA_BASE_URL: "http://ollama:11434",
      SEARXNG_BASE_URL: "http://searxng:8080",
    },
  },

  // Local search endpoint. SearXNG is key-free, but its JSON API must be enabled
  // in the SearXNG sernereuse settings.
  tools: {
    web: {
      search: {
        enabled: true,
        provider: "searxng",
      },
      fetch: {
        enabled: true,
      },
    },
  },
  plugins: {
    entries: {
      searxng: {
        enabled: true,
        config: {
          webSearch: {
            baseUrl: "${SEARXNG_BASE_URL}",
            categories: "general",
            language: "en",
          },
        },
      },
    },
  },

  // Local LLM endpoint placeholder. OpenClaw's implicit Ollama discovery uses
  // 127.0.0.1, so container-to-container Ollama should be configured explicitly
  // after choosing model IDs that exist in your Ollama sernereuse.
  // models: {
  //   providers: {
  //     ollama: {
  //       baseUrl: "${OLLAMA_BASE_URL}",
  //       apiKey: "ollama-local",
  //       api: "ollama",
  //       models: [
  //         {
  //           id: "gpt-oss:20b",
  //           name: "GPT-OSS 20B",
  //           reasoning: false,
  //           input: ["text"],
  //           cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
  //           contextWindow: 8192,
  //           maxTokens: 8192,
  //         },
  //       ],
  //     },
  //   },
  // },
}
