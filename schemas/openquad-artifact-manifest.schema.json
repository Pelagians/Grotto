{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grotto.dev/schemas/grotto-artifact-manifest.schema.json",
  "title": "Grotto Artifact Manifest",
  "type": "object",
  "required": [
    "task_id",
    "artifacts"
  ],
  "additionalProperties": true,
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "uri",
          "sha256",
          "size_bytes",
          "content_type"
        ],
        "additionalProperties": true,
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "text",
              "json",
              "csv",
              "pdf",
              "png",
              "html",
              "trace",
              "screenshot",
              "other"
            ]
          },
          "uri": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "content_type": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
