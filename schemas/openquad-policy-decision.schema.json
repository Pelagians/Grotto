{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grotto.dev/schemas/grotto-policy-decision.schema.json",
  "title": "Grotto Policy Decision Hint",
  "type": "object",
  "required": [
    "decision",
    "reason",
    "policy_version"
  ],
  "additionalProperties": true,
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "allowed",
        "requires_approval",
        "rejected"
      ]
    },
    "reason": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "hints": {
      "type": "object"
    }
  }
}
