# syntax=docker/dockerfile:1.7
ARG PLAYWRIGHT_VERSION=1.60.0
FROM mcr.microsoft.com/playwright:v${PLAYWRIGHT_VERSION}-noble

ARG PLAYWRIGHT_VERSION=1.60.0
ARG OPENQUAD_IMAGE_NAME="openquad-browser-runtime-visible"

USER root
ENV OPENQUAD_IMAGE_NAME=${OPENQUAD_IMAGE_NAME} \
    OPENQUAD_RUNTIME=browser-runtime-visible \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 \
    DISPLAY=:99 \
    SCREEN_WIDTH=1440 \
    SCREEN_HEIGHT=1000 \
    SCREEN_DEPTH=24 \
    VNC_PORT=5900 \
    NOVNC_PORT=6080 \
    CHROMIUM_CDP_HOST=0.0.0.0 \
    CHROMIUM_CDP_PORT=9222 \
    CHROMIUM_POLICY_DIR=/etc/chromium/policies/managed \
    VISIBLE_BROWSER_MODE=locked \
    CHROMIUM_START_URL=about:blank \
    BROWSER_PROFILE_DIR=/home/pwuser/browser-profile \
    BROWSER_DOWNLOAD_DIR=/home/pwuser/downloads

WORKDIR /opt/openquad/browser-runtime
RUN set -eux; \
    apt-get update; \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        fluxbox \
        novnc \
        websockify \
        x11vnc \
        xvfb; \
    rm -rf /var/lib/apt/lists/*; \
    npm init -y; \
    npm install --omit=dev "playwright@${PLAYWRIGHT_VERSION}"; \
    npm cache clean --force; \
    install -d -o pwuser -g pwuser \
        /home/pwuser/browser-profile \
        /home/pwuser/downloads \
        /home/pwuser/.vnc \
        /opt/openquad/browser-runtime \
        /usr/share/openquad/templates/browser-runtime-visible/policies; \
    install -d -m 0755 \
        /etc/chromium/policies/managed \
        /etc/chromium/policies/recommended; \
    chown -R pwuser:pwuser /opt/openquad/browser-runtime /home/pwuser

COPY runtimes/browser/visible/start-visible.sh /usr/local/bin/openquad-browser-runtime-visible
COPY templates/browser-runtime-visible/Brewfile /usr/share/openquad/templates/browser-runtime-visible/Brewfile
COPY templates/browser-runtime-visible/policies/vic-managed-policy.example.json /usr/share/openquad/templates/browser-runtime-visible/policies/vic-managed-policy.example.json
RUN set -eux; \
    chmod 0755 /usr/local/bin/openquad-browser-runtime-visible; \
    test -r /usr/share/openquad/templates/browser-runtime-visible/Brewfile; \
    test -r /usr/share/openquad/templates/browser-runtime-visible/policies/vic-managed-policy.example.json

EXPOSE 9222 5900 6080
USER pwuser
WORKDIR /home/pwuser
CMD ["/usr/local/bin/openquad-browser-runtime-visible"]
