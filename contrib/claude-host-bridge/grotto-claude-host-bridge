#!/usr/bin/env python3
from __future__ import annotations

import argparse
import fcntl
import json
import os
import shutil
import signal
import socket
import subprocess
import sys
from pathlib import Path
from typing import Any
from urllib.parse import urlparse

MAX_MESSAGE_BYTES = 64 * 1024


def runtime_root() -> Path:
    configured = os.environ.get("GROTTO_CLAUDE_BRIDGE_DIR")
    if configured:
        return Path(configured).expanduser()

    xdg_runtime = os.environ.get("XDG_RUNTIME_DIR")
    if xdg_runtime:
        return Path(xdg_runtime) / "grotto" / "claude-bridge"

    return Path(f"/run/user/{os.getuid()}") / "grotto" / "claude-bridge"


def host_socket_path() -> Path:
    return runtime_root() / "host.sock"


def claude_socket_path() -> Path:
    return runtime_root() / "claude.sock"


def receive_message(connection: socket.socket) -> dict[str, Any]:
    chunks: list[bytes] = []
    total = 0

    while True:
        chunk = connection.recv(4096)
        if not chunk:
            break
        chunks.append(chunk)
        total += len(chunk)
        if total > MAX_MESSAGE_BYTES:
            raise ValueError("bridge message exceeds maximum size")
        if b"\n" in chunk:
            break

    raw = b"".join(chunks).split(b"\n", 1)[0]
    if not raw:
        raise ValueError("empty bridge message")

    message = json.loads(raw.decode("utf-8"))
    if not isinstance(message, dict):
        raise ValueError("bridge message must be a JSON object")
    return message


def send_message(path: Path, message: dict[str, Any]) -> dict[str, Any]:
    payload = json.dumps(message, separators=(",", ":")).encode("utf-8") + b"\n"
    if len(payload) > MAX_MESSAGE_BYTES:
        raise ValueError("bridge message exceeds maximum size")

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as connection:
        connection.settimeout(5)
        connection.connect(str(path))
        connection.sendall(payload)
        response = receive_message(connection)

    if not response.get("ok"):
        raise RuntimeError(str(response.get("error", "bridge request failed")))
    return response


def send_response(connection: socket.socket, *, ok: bool, error: str | None = None) -> None:
    response: dict[str, Any] = {"ok": ok}
    if error:
        response["error"] = error
    connection.sendall(json.dumps(response, separators=(",", ":")).encode("utf-8") + b"\n")


def validate_https_url(value: object) -> str:
    if not isinstance(value, str):
        raise ValueError("URL must be a string")
    parsed = urlparse(value)
    if parsed.scheme != "https" or not parsed.netloc:
        raise ValueError("host bridge only opens absolute HTTPS URLs")
    return value


def validate_claude_uri(value: object) -> str:
    if not isinstance(value, str):
        raise ValueError("callback URI must be a string")
    if not value.startswith("claude://"):
        raise ValueError("host bridge only forwards claude:// callbacks")
    return value


def serve() -> int:
    bridge_dir = runtime_root()
    bridge_dir.mkdir(parents=True, exist_ok=True, mode=0o700)
    bridge_dir.chmod(0o700)

    lock_file = (bridge_dir / "host-listener.lock").open("a+")
    try:
        fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        print("Claude host browser bridge is already running", file=sys.stderr)
        return 1

    path = host_socket_path()
    path.unlink(missing_ok=True)

    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.bind(str(path))
    path.chmod(0o600)
    server.listen(8)

    stopping = False

    def stop(_signum: int, _frame: object) -> None:
        nonlocal stopping
        stopping = True
        server.close()

    signal.signal(signal.SIGTERM, stop)
    signal.signal(signal.SIGINT, stop)

    print(f"Claude host browser bridge listening on {path}", flush=True)

    try:
        while not stopping:
            try:
                connection, _ = server.accept()
            except OSError:
                if stopping:
                    break
                raise

            with connection:
                try:
                    message = receive_message(connection)
                    if message.get("action") != "open":
                        raise ValueError("unsupported host bridge action")
                    url = validate_https_url(message.get("url"))
                    subprocess.Popen(
                        ["xdg-open", url],
                        stdin=subprocess.DEVNULL,
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                        start_new_session=True,
                    )
                    send_response(connection, ok=True)
                    print(f"Opened authentication URL in host browser: {url}", flush=True)
                except Exception as exc:  # noqa: BLE001
                    send_response(connection, ok=False, error=str(exc))
                    print(f"Rejected bridge request: {exc}", file=sys.stderr, flush=True)
    finally:
        server.close()
        path.unlink(missing_ok=True)
        lock_file.close()

    return 0


def callback(uri: str) -> int:
    send_message(
        claude_socket_path(),
        {
            "action": "callback",
            "uri": validate_claude_uri(uri),
        },
    )
    return 0


def desktop_entry(binary: Path) -> str:
    return f"""[Desktop Entry]
Type=Application
Name=Grotto Claude callback bridge
Comment=Return Claude authentication callbacks to the Grotto container
Exec={binary} callback %u
Terminal=false
NoDisplay=true
MimeType=x-scheme-handler/claude;
Categories=Utility;
"""


def systemd_unit() -> str:
    return """[Unit]
Description=Grotto Claude host browser bridge
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/grotto-claude-host-bridge serve
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
"""


def run_optional(command: list[str]) -> bool:
    try:
        subprocess.run(command, check=True)
        return True
    except (FileNotFoundError, subprocess.CalledProcessError):
        return False


def install() -> int:
    source = Path(__file__).resolve()
    binary = Path.home() / ".local" / "bin" / "grotto-claude-host-bridge"
    applications = Path.home() / ".local" / "share" / "applications"
    desktop = applications / "grotto-claude-host-bridge.desktop"
    units = Path.home() / ".config" / "systemd" / "user"
    unit = units / "grotto-claude-host-bridge.service"

    binary.parent.mkdir(parents=True, exist_ok=True)
    applications.mkdir(parents=True, exist_ok=True)
    units.mkdir(parents=True, exist_ok=True)
    runtime_root().mkdir(parents=True, exist_ok=True, mode=0o700)
    runtime_root().chmod(0o700)

    if source != binary:
        shutil.copy2(source, binary)
    binary.chmod(0o755)
    desktop.write_text(desktop_entry(binary), encoding="utf-8")
    desktop.chmod(0o644)
    unit.write_text(systemd_unit(), encoding="utf-8")
    unit.chmod(0o644)

    run_optional(["update-desktop-database", str(applications)])
    if not run_optional(
        ["xdg-mime", "default", "grotto-claude-host-bridge.desktop", "x-scheme-handler/claude"]
    ):
        print("warning: could not register the claude:// handler", file=sys.stderr)

    systemd_ready = run_optional(["systemctl", "--user", "daemon-reload"])
    if systemd_ready:
        run_optional(
            [
                "systemctl",
                "--user",
                "import-environment",
                "DISPLAY",
                "WAYLAND_DISPLAY",
                "XAUTHORITY",
                "DBUS_SESSION_BUS_ADDRESS",
            ]
        )
        systemd_ready = run_optional(
            ["systemctl", "--user", "enable", "--now", "grotto-claude-host-bridge.service"]
        )

    print(f"Installed host bridge: {binary}")
    print(f"Bridge directory: {runtime_root()}")
    if not systemd_ready:
        print(
            "The systemd user service could not be started. "
            f"Run '{binary} serve' in the host desktop session before signing in.",
            file=sys.stderr,
        )
    return 0


def uninstall() -> int:
    binary = Path.home() / ".local" / "bin" / "grotto-claude-host-bridge"
    desktop = Path.home() / ".local" / "share" / "applications" / "grotto-claude-host-bridge.desktop"
    unit = Path.home() / ".config" / "systemd" / "user" / "grotto-claude-host-bridge.service"

    run_optional(["systemctl", "--user", "disable", "--now", "grotto-claude-host-bridge.service"])
    host_socket_path().unlink(missing_ok=True)
    desktop.unlink(missing_ok=True)
    unit.unlink(missing_ok=True)
    binary.unlink(missing_ok=True)
    run_optional(["systemctl", "--user", "daemon-reload"])
    run_optional(["update-desktop-database", str(desktop.parent)])
    print("Removed the Grotto Claude host bridge")
    return 0


def status() -> int:
    print(f"Bridge directory: {runtime_root()}")
    print(f"Host browser socket: {'ready' if host_socket_path().is_socket() else 'missing'}")
    print(f"Claude callback socket: {'ready' if claude_socket_path().is_socket() else 'missing'}")

    try:
        result = subprocess.run(
            ["xdg-mime", "query", "default", "x-scheme-handler/claude"],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
        )
        print(f"claude:// handler: {result.stdout.strip() or 'unconfigured'}")
    except (FileNotFoundError, subprocess.CalledProcessError):
        print("claude:// handler: unavailable")

    return 0 if host_socket_path().is_socket() else 1


def self_test() -> int:
    assert validate_https_url("https://accounts.google.com/o/oauth2/auth")
    assert validate_claude_uri("claude://auth/callback?code=test")

    for invalid in ("http://example.com", "file:///tmp/test", "javascript:alert(1)"):
        try:
            validate_https_url(invalid)
        except ValueError:
            pass
        else:
            raise AssertionError(f"accepted unsafe URL: {invalid}")

    try:
        validate_claude_uri("https://claude.ai/")
    except ValueError:
        pass
    else:
        raise AssertionError("accepted non-Claude callback")

    print("grotto-claude-host-bridge self-test passed")
    return 0


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Bridge Claude Desktop authentication to the host browser")
    subparsers = parser.add_subparsers(dest="command", required=True)
    subparsers.add_parser("serve", help="serve host-browser requests")
    callback_parser = subparsers.add_parser("callback", help="forward a claude:// callback")
    callback_parser.add_argument("uri")
    subparsers.add_parser("install", help="install the user service and claude:// handler")
    subparsers.add_parser("uninstall", help="remove the user service and handler")
    subparsers.add_parser("status", help="show bridge status")
    return parser.parse_args()


def main() -> int:
    if sys.argv[1:] == ["--self-test"]:
        return self_test()

    args = parse_args()
    if args.command == "serve":
        return serve()
    if args.command == "callback":
        return callback(args.uri)
    if args.command == "install":
        return install()
    if args.command == "uninstall":
        return uninstall()
    if args.command == "status":
        return status()
    raise AssertionError(f"unhandled command: {args.command}")


if __name__ == "__main__":
    raise SystemExit(main())
