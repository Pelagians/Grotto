#!/usr/bin/python3
"""Non-destructive diagnostics for the Grotto ChatGPT Desktop runtime."""

from __future__ import annotations

import argparse
import datetime
import glob
import grp
import json
import os
import pathlib
import pwd
import shutil
import socket
import stat
import subprocess
import sys
import tempfile
import urllib.error
import urllib.request
from typing import Any

SCHEMA_VERSION = 1
PROBE_CACHE_SCHEMA_VERSION = 1
CHATGPT_SECURITY_MANIFEST_SCHEMA_VERSION = 1
CHATGPT_SECURITY_MANIFEST = "/usr/share/grotto/chatgpt-desktop-security.json"
PROBE_NOT_RUN_REASON = "active probe requires --probe-sandbox"
PROBE_WARNING = (
    "WARNING: --probe-sandbox will intentionally trigger host SELinux AVCs "
    "on known-incompatible rootless Fedora hosts while it runs nested "
    "sandbox mount and remount tests."
)
AUTH_HOST = "auth.openai.com"
CODEX = "/opt/codex-cli/bin/codex"
MANAGED_NODE_DIR = "/opt/chatgpt/resources/node-runtime/bin"
WORKSPACE = "/workspace"
DIAGNOSTIC_PATH = ":".join(
    (
        "/usr/local/bin",
        "/opt/codex-cli/bin",
        MANAGED_NODE_DIR,
        "/lsiopy/bin",
        "/usr/local/sbin",
        "/usr/sbin",
        "/usr/bin",
        "/sbin",
        "/bin",
    )
)


def run(
    command: list[str],
    *,
    cwd: str | None = None,
    timeout: int = 15,
    extra_env: dict[str, str] | None = None,
) -> dict[str, Any]:
    env = os.environ.copy()
    env["PATH"] = DIAGNOSTIC_PATH
    if extra_env:
        env.update(extra_env)
    try:
        completed = subprocess.run(
            command,
            check=False,
            capture_output=True,
            text=True,
            timeout=timeout,
            env=env,
            cwd=cwd or (WORKSPACE if pathlib.Path(WORKSPACE).is_dir() else "/"),
        )
        return {
            "ok": completed.returncode == 0,
            "returncode": completed.returncode,
            "stdout": completed.stdout.strip()[:8192],
            "stderr": completed.stderr.strip()[:8192],
        }
    except (OSError, subprocess.TimeoutExpired) as exc:
        return {
            "ok": False,
            "returncode": None,
            "stdout": "",
            "stderr": str(exc)[:8192],
        }


def read_text(path: str) -> str | None:
    try:
        return pathlib.Path(path).read_text(encoding="utf-8").rstrip("\x00\n")
    except (OSError, UnicodeError):
        return None


def read_json(path: str) -> dict[str, Any]:
    try:
        value = json.loads(pathlib.Path(path).read_text(encoding="utf-8"))
        return value if isinstance(value, dict) else {}
    except (OSError, UnicodeError, json.JSONDecodeError):
        return {}


def unverified_security_policy(path: pathlib.Path, reason: str) -> dict[str, Any]:
    return {
        "node_repl_exposed": None,
        "node_repl_auto_approved": None,
        "node_repl_verified": False,
        "node_repl_policy_source": None,
        "browser_use_trusted_client_hash_patch": None,
        "browser_use_policy_verified": False,
        "manifest_path": str(path),
        "manifest_wrapper_revision": None,
        "manifest_error": reason,
    }


def read_chatgpt_desktop_security_policy(
    path: pathlib.Path | None = None,
    *,
    expected_wrapper_revision: str | None = None,
) -> dict[str, Any]:
    candidate = path or pathlib.Path(
        os.environ.get("GROTTO_CHATGPT_SECURITY_MANIFEST", CHATGPT_SECURITY_MANIFEST)
    )
    try:
        value = json.loads(candidate.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return unverified_security_policy(candidate, "security manifest is missing")
    except json.JSONDecodeError as exc:
        return unverified_security_policy(candidate, f"security manifest is malformed: {exc}")
    except (OSError, UnicodeError) as exc:
        return unverified_security_policy(candidate, f"security manifest is invalid: {exc}")

    if (
        not isinstance(value, dict)
        or value.get("schema_version") != CHATGPT_SECURITY_MANIFEST_SCHEMA_VERSION
    ):
        return unverified_security_policy(
            candidate, "security manifest schema is unsupported"
        )
    node_repl = value.get("node_repl")
    browser_use = value.get("browser_use")
    wrapper_revision = value.get("wrapper_revision")
    if not isinstance(node_repl, dict) or not isinstance(browser_use, dict):
        return unverified_security_policy(candidate, "security manifest sections are invalid")
    fields = (
        node_repl.get("exposed"),
        node_repl.get("auto_approved"),
        node_repl.get("verified"),
        browser_use.get("trusted_client_hash_patch"),
        browser_use.get("verified"),
    )
    if any(type(field) is not bool for field in fields):
        return unverified_security_policy(candidate, "security manifest fields are invalid")
    if not isinstance(wrapper_revision, str) or not wrapper_revision:
        return unverified_security_policy(candidate, "security manifest wrapper is invalid")
    if expected_wrapper_revision not in (None, "unknown", wrapper_revision):
        return unverified_security_policy(
            candidate, "security manifest wrapper does not match runtime"
        )
    source = node_repl.get("verification_source")
    if source != "installed-electron-bundle":
        return unverified_security_policy(candidate, "security manifest source is invalid")
    if not node_repl["verified"] or not browser_use["verified"]:
        return unverified_security_policy(candidate, "security manifest is unverified")

    return {
        "node_repl_exposed": node_repl["exposed"],
        "node_repl_auto_approved": node_repl["auto_approved"],
        "node_repl_verified": node_repl["verified"],
        "node_repl_policy_source": source,
        "browser_use_trusted_client_hash_patch": browser_use[
            "trusted_client_hash_patch"
        ],
        "browser_use_policy_verified": browser_use["verified"],
        "manifest_path": str(candidate),
        "manifest_wrapper_revision": wrapper_revision,
        "manifest_error": None,
    }


def utc_timestamp() -> str:
    return (
        datetime.datetime.now(datetime.timezone.utc)
        .isoformat(timespec="seconds")
        .replace("+00:00", "Z")
    )


def probe_cache_path() -> pathlib.Path:
    cache_home = os.environ.get("XDG_CACHE_HOME")
    if not cache_home:
        cache_home = str(pathlib.Path(os.environ.get("HOME", "/config")) / ".cache")
    return pathlib.Path(cache_home) / "grotto" / "doctor-sandbox-probe.json"


def read_probe_cache(path: pathlib.Path) -> tuple[dict[str, Any] | None, str | None]:
    try:
        if not path.exists():
            return None, None
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, UnicodeError, json.JSONDecodeError) as exc:
        return None, str(exc)
    if not isinstance(value, dict):
        return None, "cached probe is not a JSON object"
    if value.get("schema_version") != PROBE_CACHE_SCHEMA_VERSION:
        return None, "cached probe schema version is unsupported"
    return value, None


def write_probe_cache(path: pathlib.Path, value: dict[str, Any]) -> str | None:
    temporary_path: pathlib.Path | None = None
    try:
        path.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
        with tempfile.NamedTemporaryFile(
            mode="w",
            encoding="utf-8",
            prefix=f".{path.name}.",
            dir=path.parent,
            delete=False,
        ) as handle:
            temporary_path = pathlib.Path(handle.name)
            os.chmod(temporary_path, 0o600)
            json.dump(value, handle, indent=2, sort_keys=True)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temporary_path, path)
        return None
    except (OSError, TypeError, ValueError) as exc:
        if temporary_path is not None:
            temporary_path.unlink(missing_ok=True)
        return str(exc)


def path_status(path: str) -> dict[str, Any]:
    candidate = pathlib.Path(path)
    result: dict[str, Any] = {
        "exists": candidate.exists(),
        "writable": os.access(candidate, os.W_OK) if candidate.exists() else False,
    }
    try:
        item = candidate.stat()
        result.update(
            {
                "uid": item.st_uid,
                "gid": item.st_gid,
                "user": pwd.getpwuid(item.st_uid).pw_name,
                "group": grp.getgrgid(item.st_gid).gr_name,
                "mode": oct(item.st_mode & 0o777),
            }
        )
    except (OSError, KeyError):
        pass
    return result


def mount_entry(target: str) -> dict[str, Any]:
    result = run(
        [
            "/usr/bin/findmnt",
            "--json",
            "--target",
            target,
            "--output",
            "TARGET,SOURCE,FSTYPE,OPTIONS,PROPAGATION",
        ]
    )
    if not result["ok"]:
        return {"ok": False, "error": result["stderr"]}
    try:
        filesystems = json.loads(result["stdout"]).get("filesystems", [])
        return {"ok": True, **(filesystems[0] if filesystems else {})}
    except (json.JSONDecodeError, IndexError, TypeError):
        return {"ok": False, "error": "could not parse findmnt output"}


def proc_status() -> dict[str, int | None]:
    values: dict[str, int | None] = {
        "no_new_privs": None,
        "seccomp": None,
        "seccomp_filters": None,
    }
    mapping = {
        "NoNewPrivs": "no_new_privs",
        "Seccomp": "seccomp",
        "Seccomp_filters": "seccomp_filters",
    }
    for line in (read_text("/proc/self/status") or "").splitlines():
        key, separator, raw = line.partition(":")
        if separator and key in mapping:
            try:
                values[mapping[key]] = int(raw.strip())
            except ValueError:
                pass
    return values


def group_status() -> list[dict[str, Any]]:
    result = []
    for gid in os.getgroups():
        try:
            name = grp.getgrgid(gid).gr_name
        except KeyError:
            name = None
        result.append({"gid": gid, "name": name})
    return result


def resolve_bundled_bwrap() -> str | None:
    matches = glob.glob(
        "/opt/codex-cli/lib/node_modules/@openai/codex/**/codex-resources/bwrap",
        recursive=True,
    )
    return next((path for path in matches if os.access(path, os.X_OK)), None)


def version_info(path: str | None, args: list[str]) -> dict[str, Any]:
    if not path:
        return {"path": None, "version": None}
    result = run([path, *args])
    output = result["stdout"] or result["stderr"]
    return {"path": path, "version": output.splitlines()[0] if output else None}


def bubblewrap_version_info(
    path: str | None, system_bwrap: str | None
) -> dict[str, Any]:
    return {
        "path": path,
        "version": None,
        "version_source": (
            "PATH package metadata" if path and path == system_bwrap
            else "bundled binary not executed by default" if path
            else None
        ),
    }


def memory_status() -> dict[str, int]:
    values: dict[str, int] = {}
    for line in (read_text("/proc/meminfo") or "").splitlines():
        name, separator, raw = line.partition(":")
        if separator and name in {"MemTotal", "MemAvailable", "SwapTotal"}:
            try:
                values[f"{name.lower()}_bytes"] = int(raw.split()[0]) * 1024
            except (IndexError, ValueError):
                pass
    return values


def device_inventory() -> list[dict[str, Any]]:
    devices = []
    root = pathlib.Path("/dev")
    if not root.is_dir():
        return devices
    try:
        candidates = list(root.iterdir())
    except OSError:
        return devices
    for path in sorted(candidates, key=str):
        try:
            item = path.lstat()
        except OSError:
            continue
        kind = "directory" if stat.S_ISDIR(item.st_mode) else "other"
        if stat.S_ISCHR(item.st_mode):
            kind = "character"
        elif stat.S_ISBLK(item.st_mode):
            kind = "block"
        elif stat.S_ISLNK(item.st_mode):
            kind = "symlink"
        devices.append({"path": str(path), "kind": kind, "mode": oct(item.st_mode & 0o777)})
    return devices


def network_status() -> dict[str, Any]:
    if os.environ.get("GROTTO_DOCTOR_SKIP_NETWORK") == "1":
        skipped = {"ok": None, "skipped": True, "error": None}
        return {"host": AUTH_HOST, "dns": skipped, "https": skipped}
    addresses: list[str] = []
    dns_error = None
    try:
        addresses = sorted(
            {entry[4][0] for entry in socket.getaddrinfo(AUTH_HOST, 443, type=socket.SOCK_STREAM)}
        )
    except OSError as exc:
        dns_error = str(exc)
    https_status = None
    https_error = None
    try:
        request = urllib.request.Request(
            f"https://{AUTH_HOST}/", method="HEAD", headers={"User-Agent": "grotto-doctor/1"}
        )
        with urllib.request.urlopen(request, timeout=8) as response:
            https_status = response.status
    except urllib.error.HTTPError as exc:
        https_status = exc.code
    except (OSError, urllib.error.URLError) as exc:
        https_error = str(exc)
    return {
        "host": AUTH_HOST,
        "dns": {"ok": bool(addresses), "addresses": addresses, "error": dns_error},
        "https": {"ok": https_status is not None, "status": https_status, "error": https_error},
    }


def effective_landlock_enabled() -> tuple[bool | None, dict[str, Any]]:
    result = run([CODEX, "features", "list"])
    if not result["ok"]:
        return None, result
    for line in result["stdout"].splitlines():
        fields = line.split()
        if fields and fields[0] == "use_legacy_landlock":
            return fields[-1].lower() == "true", result
    return None, result


def missing_check(message: str) -> dict[str, Any]:
    return {"ok": False, "returncode": None, "stdout": "", "stderr": message}


def collect_sandbox_checks(
    bwrap_helper: str | None,
) -> tuple[dict[str, Any], dict[str, Any]]:
    if bwrap_helper:
        fresh_dev = run(
            [
                bwrap_helper,
                "--unshare-user",
                "--unshare-pid",
                "--ro-bind",
                "/",
                "/",
                "--dev",
                "/dev",
                "/bin/true",
            ]
        )
        with tempfile.TemporaryDirectory(prefix=".grotto-doctor-bwrap-", dir="/tmp") as probe:
            protected_remount = run(
                [
                    bwrap_helper,
                    "--unshare-user",
                    "--unshare-pid",
                    "--ro-bind",
                    "/",
                    "/",
                    "--bind",
                    probe,
                    probe,
                    "--perms",
                    "555",
                    "--tmpfs",
                    f"{probe}/.git",
                    "--remount-ro",
                    f"{probe}/.git",
                    "/bin/true",
                ]
            )
    else:
        fresh_dev = missing_check("Bubblewrap helper not found")
        protected_remount = missing_check("Bubblewrap helper not found")

    probe_parent = WORKSPACE if os.access(WORKSPACE, os.W_OK) else "/tmp"
    with tempfile.TemporaryDirectory(prefix=".grotto-doctor-codex-", dir=probe_parent) as probe:
        for name in (".git", ".agents", ".codex"):
            protected = pathlib.Path(probe, name)
            protected.mkdir()
            pathlib.Path(protected, "seed").write_text("seed\n", encoding="utf-8")
        codex_workspace = run(
            [
                CODEX,
                "sandbox",
                "-P",
                ":workspace",
                "-C",
                probe,
                "--",
                "/bin/sh",
                "-c",
                "touch ordinary && rm ordinary && ! touch .git/blocked && ! touch .agents/blocked && ! touch .codex/blocked && ! touch /etc/grotto-doctor-blocked",
            ],
            cwd=probe,
        )
        landlock_workspace = run(
            [
                CODEX,
                "sandbox",
                "-P",
                ":workspace",
                "-C",
                probe,
                "--enable",
                "use_legacy_landlock",
                "--",
                "/bin/true",
            ],
            cwd=probe,
        )
    checks = {
        "direct_command": run(["/bin/true"]),
        "bubblewrap_fresh_dev": fresh_dev,
        "bubblewrap_protected_child_remount": protected_remount,
        "codex_workspace_permissions": codex_workspace,
        "landlock_workspace_profile": landlock_workspace,
    }
    return checks, {
        "root": "temporary directory removed after checks",
        "protected_paths": [".git", ".agents", ".codex"],
        "ordinary_write_checked": True,
        "outside_write_checked": "/etc/grotto-doctor-blocked",
    }


def run_sandbox_probe(
    bwrap_helper: str | None, selected_backend: str
) -> dict[str, Any]:
    started_at = utc_timestamp()
    checks, details = collect_sandbox_checks(bwrap_helper)
    completed_at = utc_timestamp()
    ok = bool(checks["direct_command"]["ok"] and checks["codex_workspace_permissions"]["ok"])
    return {
        "schema_version": PROBE_CACHE_SCHEMA_VERSION,
        "status": "completed",
        "reason": None,
        "active_probe": True,
        "may_generate_host_avcs": True,
        "probe_started_at": started_at,
        "probe_completed_at": completed_at,
        "selected_backend": selected_backend,
        "selected_bwrap": bwrap_helper,
        "ok": ok,
        "checks": checks,
        "details": details,
    }


def collect(*, active_probe: bool = False) -> dict[str, Any]:
    build_info = read_json("/opt/chatgpt/.codex-linux/build-info.json")
    upstream = build_info.get("upstreamDmg", {})
    source = build_info.get("source", {})
    wrapper_revision = os.environ.get(
        "GROTTO_CODEX_DESKTOP_LINUX_REF", source.get("commit", "unknown")
    )
    desktop_policy = read_chatgpt_desktop_security_policy(
        expected_wrapper_revision=wrapper_revision
    )
    bundled_bwrap = resolve_bundled_bwrap()
    system_bwrap = shutil.which("bwrap", path=DIAGNOSTIC_PATH)
    selected_bwrap = system_bwrap or bundled_bwrap
    selected_backend, feature_listing = effective_landlock_enabled()
    backend = "landlock" if selected_backend else "bubblewrap"
    cache_path = probe_cache_path()
    cached_probe, cache_read_error = read_probe_cache(cache_path)
    cache_write_error = None
    if active_probe:
        sandbox_probe = run_sandbox_probe(selected_bwrap, backend)
        cache_write_error = write_probe_cache(cache_path, sandbox_probe)
        if cache_write_error is None:
            cached_probe = sandbox_probe
            cache_read_error = None
    else:
        sandbox_probe = {
            "status": "not_run",
            "reason": PROBE_NOT_RUN_REASON,
            "ok": None,
            "checks": {},
            "details": None,
        }
    checks = sandbox_probe["checks"]

    command_paths = {
        name: shutil.which(name, path=DIAGNOSTIC_PATH)
        for name in (
            "bash", "git", "curl", "jq", "gh", "lsof", "pkg-config", "pip3",
            "python3", "rg", "shellcheck", "sqlite3", "unzip", "zip",
        )
    }
    tools = {
        "codex": version_info(CODEX, ["--version"]),
        "node": version_info(f"{MANAGED_NODE_DIR}/node", ["--version"]),
        "npm": version_info(f"{MANAGED_NODE_DIR}/npm", ["--version"]),
        "python": version_info(command_paths["python3"], ["--version"]),
        "pip": version_info(command_paths["pip3"], ["--version"]),
        "git": version_info(command_paths["git"], ["--version"]),
        "ripgrep": version_info(command_paths["rg"], ["--version"]),
        "jq": version_info(command_paths["jq"], ["--version"]),
        "gh": version_info(command_paths["gh"], ["--version"]),
        "bubblewrap": bubblewrap_version_info(selected_bwrap, system_bwrap),
        "shellcheck": version_info(command_paths["shellcheck"], ["--version"]),
        "sqlite3": version_info(command_paths["sqlite3"], ["--version"]),
    }
    host_audit_access = os.access("/var/log/audit/audit.log", os.R_OK)
    remediation: list[str] = []
    if desktop_policy["manifest_error"]:
        remediation.append(
            "The image lacks verified ChatGPT Desktop build policy metadata at "
            f"{desktop_policy['manifest_path']}: {desktop_policy['manifest_error']}. "
            "Rebuild the image with installed-app policy verification enabled."
        )
    elif desktop_policy["node_repl_auto_approved"]:
        remediation.append("Node REPL JavaScript is reported as automatically approved.")
    if active_probe:
        if "Can't mount devpts" in checks["bubblewrap_fresh_dev"]["stderr"]:
            remediation.append(
                "Codex's fresh minimal /dev setup is blocked at the nested devpts mount."
            )
        if "Can't remount readonly" in checks["bubblewrap_protected_child_remount"]["stderr"]:
            remediation.append(
                "Bubblewrap cannot remount synthetic protected metadata paths read-only."
            )
        if not checks["codex_workspace_permissions"]["ok"]:
            remediation.append(
                "The Codex workspace sandbox is not ready; preserve SELinux and normal Podman seccomp."
            )
    if not pathlib.Path("/dev/dri").exists():
        remediation.append("No /dev/dri device is available; software rendering will be used.")

    report: dict[str, Any] = {
        "schema_version": SCHEMA_VERSION,
        "ok": sandbox_probe["ok"],
        "active_probe": active_probe,
        "node_repl_exposed": desktop_policy["node_repl_exposed"],
        "node_repl_auto_approved": desktop_policy["node_repl_auto_approved"],
        "node_repl_verified": desktop_policy["node_repl_verified"],
        "node_repl_policy_source": desktop_policy["node_repl_policy_source"],
        "browser_use_trusted_client_hash_patch": desktop_policy[
            "browser_use_trusted_client_hash_patch"
        ],
        "browser_use_policy_verified": desktop_policy["browser_use_policy_verified"],
        "chatgpt_desktop_security": {
            key: desktop_policy[key]
            for key in ("manifest_path", "manifest_wrapper_revision", "manifest_error")
        },
        "may_generate_host_avcs": active_probe,
        "probe_started_at": sandbox_probe.get("probe_started_at"),
        "probe_completed_at": sandbox_probe.get("probe_completed_at"),
        "sandbox_probe": sandbox_probe,
        "cached_sandbox_probe": {
            "path": str(cache_path),
            "result": cached_probe,
            "read_error": cache_read_error,
            "write_error": cache_write_error,
        },
        "runtime": {
            "name": os.environ.get("GROTTO_RUNTIME", "chatgpt-desktop"),
            "build_revision": os.environ.get("GROTTO_BUILD_REVISION", "unknown"),
            "wrapper_revision": wrapper_revision,
            "codex_cli_build_version": os.environ.get(
                "GROTTO_CODEX_CLI_VERSION", tools["codex"]["version"] or "unknown"
            ),
            "selkies_base_image": os.environ.get("GROTTO_SELKIES_BASE_IMAGE", "unknown"),
            "desktop": {
                "app_version": upstream.get("appVersion"),
                "dmg_sha256": upstream.get("sha256"),
                "electron_version": build_info.get("electronVersion"),
            },
        },
        "identity": {
            "uid": os.getuid(),
            "gid": os.getgid(),
            "user": pwd.getpwuid(os.getuid()).pw_name,
            "group": grp.getgrgid(os.getgid()).gr_name,
            "supplementary_groups": group_status(),
        },
        "environment": {
            key: os.environ.get(key)
            for key in ("HOME", "CODEX_HOME", "XDG_CONFIG_HOME", "XDG_CACHE_HOME", "XDG_STATE_HOME", "PATH")
        },
        "paths": {path: path_status(path) for path in ("/config", "/workspace", "/tools", "/cache")},
        "mounts": {
            "/": mount_entry("/"),
            "/config": mount_entry("/config"),
            "/workspace": mount_entry("/workspace"),
            "/dev/pts": mount_entry("/dev/pts"),
            "/dev/shm": mount_entry("/dev/shm"),
        },
        "security": {
            **proc_status(),
            "selinux_context": read_text("/proc/self/attr/current"),
            "pid1_selinux_context": read_text("/proc/1/attr/current"),
            "selinux": {
                "process_context": read_text("/proc/self/attr/current"),
                "pid1_context": read_text("/proc/1/attr/current"),
                "host_audit_access": host_audit_access,
                "attribution": "requires_host_audit_review" if host_audit_access else "unknown_without_host_audit",
            },
            "max_user_namespaces": read_text("/proc/sys/user/max_user_namespaces"),
            "unprivileged_userns_clone": read_text("/proc/sys/kernel/unprivileged_userns_clone"),
            "uid_map": read_text("/proc/self/uid_map"),
            "gid_map": read_text("/proc/self/gid_map"),
        },
        "hardware": {
            "dri_available": pathlib.Path("/dev/dri").is_dir(),
            "devices": device_inventory(),
            "memory": memory_status(),
        },
        "command_paths": command_paths,
        "tools": tools,
        "sandbox": {
            "selected_backend": backend,
            "selection_source": "effective Codex feature configuration",
            "automatic_fallback_enabled": False,
            "backend_working": checks["codex_workspace_permissions"]["ok"] if active_probe else None,
            "feature_listing": feature_listing,
            "selected_bwrap": selected_bwrap,
            "selected_bwrap_source": "PATH" if system_bwrap else "codex-bundled" if bundled_bwrap else "missing",
            "system_bwrap": system_bwrap,
            "bundled_bwrap": bundled_bwrap,
            "probe": {
                "status": sandbox_probe["status"],
                "reason": sandbox_probe["reason"],
                "details": sandbox_probe["details"],
            },
            "known_fedora_compatibility": {
                "status": "known_incompatible",
                "scope": "nested Bubblewrap devpts mounts and protected-path remounts under rootless Fedora SELinux",
                "ordinary_runtime_denials_observed": False,
                "security_boundaries_unchanged": True,
            },
            "limitations": [
                "Legacy Landlock is not equivalent to Bubblewrap for split filesystem profiles.",
                "Managed proxy-only networking requires Bubblewrap.",
                "No Grotto automatic backend fallback is installed.",
            ],
        },
        "checks": checks,
        "network": network_status(),
        "remediation": remediation,
    }
    return report


def render_human(report: dict[str, Any]) -> str:
    def state(value: Any) -> str:
        return "unknown" if value is None else str(value)

    if report["active_probe"]:
        overall = "ok" if report["ok"] else "attention required"
        working = str(report["sandbox"]["backend_working"])
    else:
        overall = "static diagnostics collected; sandbox probe not run"
        working = "untested"
    lines = [
        "Grotto ChatGPT Desktop doctor",
        f"overall: {overall}",
        f"sandbox: selected={report['sandbox']['selected_backend']} working={working} automatic_fallback=false",
        "sandbox probe: " + report["sandbox_probe"]["status"] + (
            f" ({report['sandbox_probe']['reason']})" if report["sandbox_probe"]["reason"] else ""
        ),
        f"codex: {report['tools']['codex']['version'] or 'unavailable'}",
        f"wrapper: {report['runtime']['wrapper_revision']}",
        (
            "node_repl: "
            f"exposed={state(report['node_repl_exposed'])} "
            f"auto_approved={state(report['node_repl_auto_approved'])} "
            f"verified={state(report['node_repl_verified'])} "
            f"policy_source={report['node_repl_policy_source'] or 'unknown'}"
        ),
        (
            "browser_use: trusted_client_hash_patch="
            f"{state(report['browser_use_trusted_client_hash_patch'])} "
            f"verified={state(report['browser_use_policy_verified'])}"
        ),
        f"identity: {report['identity']['user']} uid={report['identity']['uid']} gid={report['identity']['gid']}",
        (
            "selinux: host_audit_access="
            f"{report['security']['selinux']['host_audit_access']} "
            f"attribution={report['security']['selinux']['attribution']}"
        ),
    ]
    if report["active_probe"]:
        lines.extend(
            (
                "sandbox probe may generate host AVCs: true",
                f"sandbox probe started: {report['probe_started_at']}",
                f"sandbox probe completed: {report['probe_completed_at']}",
            )
        )
    cached_probe = report["cached_sandbox_probe"]["result"]
    lines.append(
        "cached sandbox probe: "
        + (f"completed={cached_probe.get('probe_completed_at')} ok={cached_probe.get('ok')}" if cached_probe else "unavailable")
    )
    for name, check in report["checks"].items():
        detail = check["stderr"].splitlines()[0] if check["stderr"] else ""
        lines.append(f"check {name}: {'pass' if check['ok'] else 'fail'}" + (f" ({detail})" if detail else ""))
    lines.append(f"network: dns={report['network']['dns']['ok']} https={report['network']['https']['ok']}")
    for path, status in report["paths"].items():
        lines.append(f"path {path}: exists={status['exists']} writable={status['writable']}")
    for item in report["remediation"]:
        lines.append(f"remediation: {item}")
    return "\n".join(lines)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true", help="emit stable machine-readable JSON")
    parser.add_argument(
        "--probe-sandbox",
        action="store_true",
        help="actively execute sandbox tests; may generate host AVCs",
    )
    args = parser.parse_args(argv)
    if args.probe_sandbox:
        print(PROBE_WARNING, file=sys.stderr)
    report = collect(active_probe=args.probe_sandbox)
    if args.json:
        json.dump(report, sys.stdout, indent=2, sort_keys=True)
        sys.stdout.write("\n")
    else:
        print(render_human(report))
    if not args.probe_sandbox:
        return 0
    return 0 if report["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
