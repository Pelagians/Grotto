#!/bin/bash
set -Eeuo pipefail

export HOME="${HOME:-/config}"
export CODEX_HOME="${CODEX_HOME:-/config/.codex}"
export PATH="/tools/bin:/tools/npm/bin:/tools/pnpm:/tools/cargo/bin:/tools/mise/shims:/opt/codex-cli/bin:/opt/chatgpt/resources/node-runtime/bin:/lsiopy/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

install -d -m 0755 \
    /config/.cache \
    /config/.config \
    /config/.local/state \
    /workspace
install -d -m 0700 /config/.codex

case "${GROTTO_CHATGPT_AUTH_MODE:-device}" in
    off)
        ;;
    device|auto)
        if ! /opt/codex-cli/bin/codex login status >/dev/null 2>&1; then
            # Selkies launches this process as abc. The dialog starts Codex with
            # stdin disconnected, so ordinary keyboard input cannot dismiss it.
            if /usr/local/bin/grotto-chatgpt-auth; then
                auth_rc=0
            else
                auth_rc=$?
            fi

            case "$auth_rc" in
                0)
                    ;;
                2)
                    echo "[grotto] ChatGPT authentication skipped by user" >&2
                    ;;
                *)
                    echo "[grotto] ChatGPT authentication window exited without a session" >&2
                    ;;
            esac
        fi
        ;;
    *)
        echo "[grotto] Unknown GROTTO_CHATGPT_AUTH_MODE=${GROTTO_CHATGPT_AUTH_MODE}" >&2
        ;;
esac

cd /workspace
exec /opt/chatgpt/start.sh
