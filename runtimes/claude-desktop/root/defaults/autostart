#!/bin/bash
set -Eeuo pipefail

export HOME="${HOME:-/config}"
export CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-/config/.claude}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-/config/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-/config/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-/config/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-/config/.local/state}"
export GROTTO_CLAUDE_VIEWER_EVENT_FILE="${GROTTO_CLAUDE_VIEWER_EVENT_FILE:-/usr/share/selkies/web/grotto-claude-open-url.json}"
export GROTTO_CLAUDE_CALLBACK_PORT="${GROTTO_CLAUDE_CALLBACK_PORT:-17888}"
export BROWSER="${BROWSER:-/usr/local/bin/grotto-claude-browser}"

install -d -m 0755 \
    "$XDG_CONFIG_HOME" \
    "$XDG_CACHE_HOME" \
    "$XDG_DATA_HOME" \
    "$XDG_STATE_HOME" \
    "$XDG_CACHE_HOME/grotto" \
    /workspace
install -d -m 0700 \
    "$CLAUDE_CONFIG_DIR" \
    "$XDG_DATA_HOME/keyrings"

# Claude Desktop delegates Google OAuth to the system browser. Grotto registers
# a restricted HTTPS handler that publishes the URL into Selkies' authenticated
# web root. The connected viewer then presents a browser-native link, ensuring
# the page opens on the device actually viewing the streamed session.
xdg-mime default grotto-claude-browser.desktop text/html
xdg-mime default grotto-claude-browser.desktop x-scheme-handler/http
xdg-mime default grotto-claude-browser.desktop x-scheme-handler/https

# The browser cannot register a web handler for Anthropic's claude:// scheme.
# Run a loopback-only callback relay in this graphical session so the viewer can
# paste the callback link and deliver it to the existing Claude Desktop process.
/usr/local/bin/grotto-claude-callback-relay \
    >> "$XDG_CACHE_HOME/grotto/claude-callback-relay.log" 2>&1 &

# Claude and desktop extensions use the Secret Service API for sensitive state.
# Selkies normally provides a session D-Bus. Start only the secrets component
# and preserve any environment values returned by an already-running daemon.
if command -v gnome-keyring-daemon >/dev/null 2>&1; then
    keyring_environment="$(
        gnome-keyring-daemon --start --components=secrets 2>/dev/null || true
    )"
    if [[ -n "$keyring_environment" ]]; then
        eval "$keyring_environment"
    fi
fi

cd /workspace
exec /usr/bin/claude-desktop
