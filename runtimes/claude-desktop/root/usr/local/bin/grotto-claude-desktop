#!/bin/bash
set -Eeuo pipefail

# Grotto's primary Claude lane is X11/Openbox. Disable Chromium's custom
# titlebar so Claude cannot render its own minimize/maximize/close overlay, then
# ask Electron for a native system frame. Openbox removes that native frame from
# the main Claude surface while retaining normal frames for Firefox and dialogs.
export CLAUDE_NATIVE_TITLEBAR="${CLAUDE_NATIVE_TITLEBAR:-1}"
export ELECTRON_FORCE_IS_PACKAGED="${ELECTRON_FORCE_IS_PACKAGED:-true}"
export ELECTRON_USE_SYSTEM_TITLE_BAR="${ELECTRON_USE_SYSTEM_TITLE_BAR:-1}"

exec /usr/bin/claude-desktop \
    --ozone-platform=x11 \
    --disable-features=CustomTitlebar,WaylandWindowDecorations \
    "$@"
