#!/usr/bin/env python3
from __future__ import annotations

import errno
import fcntl
import json
import os
import subprocess
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer
from pathlib import Path
from urllib.parse import urlparse

LISTEN_HOST = "127.0.0.1"
DEFAULT_PORT = 17888
MAX_BODY_BYTES = 64 * 1024


def callback_port() -> int:
    value = int(os.environ.get("GROTTO_CLAUDE_CALLBACK_PORT", str(DEFAULT_PORT)))
    if not 1 <= value <= 65535:
        raise ValueError("callback port must be between 1 and 65535")
    return value


def validate_callback(value: object) -> str:
    if not isinstance(value, str):
        raise ValueError("callback URI must be a string")
    if len(value.encode("utf-8")) > MAX_BODY_BYTES:
        raise ValueError("callback URI is too long")

    parsed = urlparse(value)
    if parsed.scheme != "claude" or not value.startswith("claude://"):
        raise ValueError("only claude:// callback URIs are accepted")
    return value


def launch_callback(uri: str) -> None:
    subprocess.Popen(
        ["/usr/bin/claude-desktop", uri],
        env=os.environ.copy(),
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


class CallbackHandler(BaseHTTPRequestHandler):
    server_version = "GrottoClaudeCallback/1"

    def log_message(self, _format: str, *_args: object) -> None:
        # Callback URLs may contain short-lived credentials. Never log requests.
        return

    def send_json(self, status: int, payload: dict[str, object]) -> None:
        encoded = json.dumps(payload, separators=(",", ":")).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(encoded)))
        self.end_headers()
        self.wfile.write(encoded)

    def do_POST(self) -> None:  # noqa: N802
        if self.path != "/callback":
            self.send_json(404, {"ok": False, "error": "not found"})
            return

        if self.headers.get("X-Grotto-Claude-Relay") != "1":
            self.send_json(403, {"ok": False, "error": "missing relay header"})
            return

        content_type = self.headers.get("Content-Type", "").split(";", 1)[0].strip().lower()
        if content_type != "application/json":
            self.send_json(415, {"ok": False, "error": "application/json required"})
            return

        try:
            length = int(self.headers.get("Content-Length", "0"))
        except ValueError:
            self.send_json(400, {"ok": False, "error": "invalid content length"})
            return

        if length <= 0 or length > MAX_BODY_BYTES:
            self.send_json(413, {"ok": False, "error": "callback payload is too large"})
            return

        try:
            message = json.loads(self.rfile.read(length).decode("utf-8"))
            if not isinstance(message, dict):
                raise ValueError("callback payload must be a JSON object")
            uri = validate_callback(message.get("uri"))
            launch_callback(uri)
        except (UnicodeDecodeError, json.JSONDecodeError, ValueError) as exc:
            self.send_json(400, {"ok": False, "error": str(exc)})
            return
        except OSError:
            self.send_json(500, {"ok": False, "error": "unable to launch Claude Desktop"})
            return

        self.send_json(200, {"ok": True})

    def do_OPTIONS(self) -> None:  # noqa: N802
        # Cross-origin callers receive no CORS headers. The Selkies viewer uses a
        # same-origin JSON request with a custom header.
        self.send_response(204)
        self.send_header("Allow", "POST")
        self.send_header("Content-Length", "0")
        self.end_headers()

    def do_GET(self) -> None:  # noqa: N802
        self.send_json(405, {"ok": False, "error": "method not allowed"})


def serve() -> int:
    cache_dir = Path(os.environ.get("XDG_CACHE_HOME", "/config/.cache")) / "grotto"
    cache_dir.mkdir(parents=True, exist_ok=True)
    lock_file = (cache_dir / "claude-callback-relay.lock").open("a+")

    try:
        fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        print("Claude callback relay is already running", flush=True)
        return 0

    port = callback_port()
    try:
        server = HTTPServer((LISTEN_HOST, port), CallbackHandler)
    except OSError as exc:
        if exc.errno == errno.EADDRINUSE:
            print("Claude callback relay port is already in use", flush=True)
            return 0
        raise

    print(f"Claude callback relay listening on {LISTEN_HOST}:{port}", flush=True)
    try:
        server.serve_forever(poll_interval=0.5)
    finally:
        server.server_close()
        lock_file.close()
    return 0


def self_test() -> int:
    assert validate_callback("claude://auth/callback?code=test")
    for invalid in ("https://claude.ai/", "file:///tmp/test", "javascript:alert(1)"):
        try:
            validate_callback(invalid)
        except ValueError:
            pass
        else:
            raise AssertionError(f"accepted unsafe callback: {invalid}")
    assert callback_port() == DEFAULT_PORT
    print("grotto-claude-callback-relay self-test passed")
    return 0


def main() -> int:
    if len(sys.argv) == 2 and sys.argv[1] == "--self-test":
        return self_test()
    if len(sys.argv) != 1:
        print("usage: grotto-claude-callback-relay [--self-test]", file=sys.stderr)
        return 64
    return serve()


if __name__ == "__main__":
    raise SystemExit(main())
