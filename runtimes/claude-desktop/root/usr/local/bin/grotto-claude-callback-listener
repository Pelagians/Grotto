#!/usr/bin/env python3
from __future__ import annotations

import fcntl
import json
import os
import signal
import socket
import subprocess
import sys
from pathlib import Path
from typing import Any

MAX_MESSAGE_BYTES = 64 * 1024


def bridge_dir() -> Path:
    return Path(os.environ.get("GROTTO_CLAUDE_BRIDGE_DIR", "/run/grotto/claude-bridge"))


def callback_socket() -> Path:
    return bridge_dir() / "claude.sock"


def receive_message(connection: socket.socket) -> dict[str, Any]:
    chunks: list[bytes] = []
    total = 0

    while True:
        chunk = connection.recv(4096)
        if not chunk:
            break
        chunks.append(chunk)
        total += len(chunk)
        if total > MAX_MESSAGE_BYTES:
            raise ValueError("callback message exceeds maximum size")
        if b"\n" in chunk:
            break

    raw = b"".join(chunks).split(b"\n", 1)[0]
    if not raw:
        raise ValueError("empty callback message")

    message = json.loads(raw.decode("utf-8"))
    if not isinstance(message, dict):
        raise ValueError("callback message must be a JSON object")
    return message


def send_response(connection: socket.socket, *, ok: bool, error: str | None = None) -> None:
    response: dict[str, Any] = {"ok": ok}
    if error:
        response["error"] = error
    connection.sendall(json.dumps(response, separators=(",", ":")).encode("utf-8") + b"\n")


def validate_callback(value: object) -> str:
    if not isinstance(value, str):
        raise ValueError("callback URI must be a string")
    if not value.startswith("claude://"):
        raise ValueError("only claude:// callbacks are accepted")
    return value


def launch_callback(uri: str) -> None:
    subprocess.Popen(
        ["/usr/bin/claude-desktop", uri],
        env=os.environ.copy(),
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def serve() -> int:
    directory = bridge_dir()
    directory.mkdir(parents=True, exist_ok=True, mode=0o777)

    lock_path = directory / "claude-listener.lock"
    lock_file = lock_path.open("a+")
    try:
        fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        print("Claude callback listener is already running", flush=True)
        return 0

    path = callback_socket()
    path.unlink(missing_ok=True)

    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.bind(str(path))
    path.chmod(0o666)
    server.listen(8)

    stopping = False

    def stop(_signum: int, _frame: object) -> None:
        nonlocal stopping
        stopping = True
        server.close()

    signal.signal(signal.SIGTERM, stop)
    signal.signal(signal.SIGINT, stop)

    print(f"Claude callback listener ready on {path}", flush=True)

    try:
        while not stopping:
            try:
                connection, _ = server.accept()
            except OSError:
                if stopping:
                    break
                raise

            with connection:
                try:
                    message = receive_message(connection)
                    if message.get("action") != "callback":
                        raise ValueError("unsupported callback action")
                    uri = validate_callback(message.get("uri"))
                    launch_callback(uri)
                    send_response(connection, ok=True)
                    print("Forwarded authentication callback to Claude Desktop", flush=True)
                except Exception as exc:  # noqa: BLE001
                    send_response(connection, ok=False, error=str(exc))
                    print(f"Rejected Claude callback: {exc}", file=sys.stderr, flush=True)
    finally:
        server.close()
        path.unlink(missing_ok=True)
        lock_file.close()

    return 0


def self_test() -> int:
    assert validate_callback("claude://auth/callback?code=test")
    try:
        validate_callback("https://claude.ai/")
    except ValueError:
        pass
    else:
        raise AssertionError("accepted non-Claude callback")
    assert callback_socket().name == "claude.sock"
    print("grotto-claude-callback-listener self-test passed")
    return 0


def main() -> int:
    if len(sys.argv) == 2 and sys.argv[1] == "--self-test":
        return self_test()
    if len(sys.argv) != 1:
        print("usage: grotto-claude-callback-listener [--self-test]", file=sys.stderr)
        return 64
    return serve()


if __name__ == "__main__":
    raise SystemExit(main())
