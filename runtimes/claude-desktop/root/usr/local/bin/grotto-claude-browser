#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys
import tempfile
import time
import uuid
from pathlib import Path
from urllib.parse import urlparse

MAX_URL_LENGTH = 16 * 1024
DEFAULT_EVENT_FILE = Path("/usr/share/selkies/web/grotto-claude-open-url.json")


def event_file() -> Path:
    configured = os.environ.get("GROTTO_CLAUDE_VIEWER_EVENT_FILE")
    return Path(configured) if configured else DEFAULT_EVENT_FILE


def validate_url(value: str) -> str:
    if len(value.encode("utf-8")) > MAX_URL_LENGTH:
        raise ValueError("authentication URL is too long")
    parsed = urlparse(value)
    if parsed.scheme != "https" or not parsed.netloc:
        raise ValueError("Claude viewer bridge only opens absolute HTTPS URLs")
    return value


def wait_for_event_file(path: Path, timeout_seconds: float = 10.0) -> None:
    deadline = time.monotonic() + timeout_seconds
    while not path.exists():
        if time.monotonic() >= deadline:
            raise FileNotFoundError(f"Selkies viewer event file is not ready: {path}")
        time.sleep(0.25)


def write_event(url: str, path: Path | None = None) -> dict[str, object]:
    target = path or event_file()
    validated = validate_url(url)
    wait_for_event_file(target)

    event: dict[str, object] = {
        "version": 1,
        "id": uuid.uuid4().hex,
        "created_at": int(time.time() * 1000),
        "url": validated,
    }

    # The event file is pre-created and owned by the Selkies desktop user. A
    # brief partial read is harmless because the viewer retries JSON parsing.
    with target.open("w", encoding="utf-8") as handle:
        json.dump(event, handle, separators=(",", ":"))
        handle.write("\n")
        handle.flush()
        os.fsync(handle.fileno())

    return event


def self_test() -> int:
    assert validate_url("https://accounts.google.com/o/oauth2/auth")
    for invalid in ("http://example.com", "file:///tmp/test", "javascript:alert(1)"):
        try:
            validate_url(invalid)
        except ValueError:
            pass
        else:
            raise AssertionError(f"accepted unsafe URL: {invalid}")

    with tempfile.TemporaryDirectory() as temporary_directory:
        target = Path(temporary_directory) / "event.json"
        target.write_text("{}\n", encoding="utf-8")
        event = write_event("https://example.com/login", target)
        stored = json.loads(target.read_text(encoding="utf-8"))
        assert stored == event
        assert stored["version"] == 1
        assert stored["url"] == "https://example.com/login"
        assert isinstance(stored["id"], str) and stored["id"]
        assert isinstance(stored["created_at"], int)

    print("grotto-claude-browser self-test passed")
    return 0


def main() -> int:
    if len(sys.argv) == 2 and sys.argv[1] == "--self-test":
        return self_test()

    urls = [argument for argument in sys.argv[1:] if argument]
    if not urls:
        print("No URL was provided to the Claude viewer bridge", file=sys.stderr)
        return 64

    try:
        for url in urls:
            write_event(url)
    except Exception as exc:  # noqa: BLE001
        cache_dir = Path(os.environ.get("XDG_CACHE_HOME", "/config/.cache")) / "grotto"
        try:
            cache_dir.mkdir(parents=True, exist_ok=True)
            (cache_dir / "claude-viewer-bridge-error.log").write_text(
                f"{exc}\n", encoding="utf-8"
            )
        except OSError:
            pass
        print(f"Unable to send the URL to the Selkies viewer: {exc}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
