#!/usr/bin/env python3
"""Patch Claude Desktop's main BrowserWindow into X11-native titlebar mode."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
from pathlib import Path
import re
import stat
import struct
import tempfile
from typing import Any, Iterator

PATCH_MARKER = "GROTTO_X11_NATIVE_TITLEBAR"
DEFAULT_REPORT_PATH = Path("/usr/share/grotto/claude-titlebar-patch.json")
TITLEBAR_PATTERN = re.compile(
    rb'titleBarStyle:"hidden",titleBarOverlay:([A-Za-z_$][\w$]*)'
)
TEXT_SUFFIXES = {".js", ".mjs", ".cjs"}
MAX_SOURCE_SIZE = 64 * 1024 * 1024


def read_asar(bundle: Path) -> tuple[dict[str, Any], bytes]:
    """Read an Electron ASAR header and return its relative-offset data region."""
    with bundle.open("rb") as handle:
        size_pickle = handle.read(8)
        if len(size_pickle) != 8:
            raise ValueError(f"{bundle}: incomplete ASAR size pickle")
        header_size = struct.unpack_from("<I", size_pickle, 4)[0]
        if not 8 <= header_size <= 128 * 1024 * 1024:
            raise ValueError(f"{bundle}: implausible ASAR header size {header_size}")
        header_pickle = handle.read(header_size)
        if len(header_pickle) != header_size:
            raise ValueError(f"{bundle}: incomplete ASAR header")
        data = handle.read()

    if len(header_pickle) < 8:
        raise ValueError(f"{bundle}: malformed ASAR header pickle")
    json_size = struct.unpack_from("<I", header_pickle, 4)[0]
    if json_size <= 0 or 8 + json_size > len(header_pickle):
        raise ValueError(f"{bundle}: invalid ASAR JSON size {json_size}")
    raw_json = header_pickle[8 : 8 + json_size].rstrip(b"\x00")
    header = json.loads(raw_json.decode("utf-8"))
    if not isinstance(header, dict) or not isinstance(header.get("files"), dict):
        raise ValueError(f"{bundle}: ASAR header lacks files mapping")
    return header, data


def encode_header(header: dict[str, Any]) -> bytes:
    """Serialize an ASAR JSON header using Chromium Pickle framing."""
    raw_json = json.dumps(
        header,
        ensure_ascii=False,
        separators=(",", ":"),
    ).encode("utf-8")
    string_payload = struct.pack("<I", len(raw_json)) + raw_json
    string_payload += b"\x00" * ((-len(string_payload)) % 4)
    header_pickle = struct.pack("<I", len(string_payload)) + string_payload
    size_pickle = struct.pack("<II", 4, len(header_pickle))
    return size_pickle + header_pickle


def walk_entries(
    files: dict[str, Any],
    prefix: str = "",
) -> Iterator[tuple[str, dict[str, Any]]]:
    for name, raw_entry in files.items():
        if not isinstance(raw_entry, dict):
            continue
        path = f"{prefix}/{name}" if prefix else name
        children = raw_entry.get("files")
        if isinstance(children, dict):
            yield from walk_entries(children, path)
        else:
            yield path, raw_entry


def locate_entry(header: dict[str, Any], path: str) -> dict[str, Any]:
    files = header["files"]
    entry: dict[str, Any] | None = None
    components = path.split("/")
    for index, component in enumerate(components):
        raw_entry = files.get(component)
        if not isinstance(raw_entry, dict):
            raise ValueError(f"ASAR target missing: {path}")
        entry = raw_entry
        if index != len(components) - 1:
            children = raw_entry.get("files")
            if not isinstance(children, dict):
                raise ValueError(f"ASAR target path is not a directory: {component}")
            files = children
    assert entry is not None
    return entry


def packed_content(entry: dict[str, Any], data: bytes) -> bytes:
    try:
        offset = int(entry["offset"])
        size = int(entry["size"])
    except (KeyError, TypeError, ValueError) as exc:
        raise ValueError("ASAR target lacks packed offset/size") from exc
    content = data[offset : offset + size]
    if len(content) != size:
        raise ValueError("ASAR target extends beyond packed data")
    return content


def unpacked_target(bundle: Path, path: str) -> Path:
    return Path(f"{bundle}.unpacked") / path


def entry_content(
    bundle: Path,
    path: str,
    entry: dict[str, Any],
    data: bytes,
) -> bytes:
    if entry.get("unpacked"):
        return unpacked_target(bundle, path).read_bytes()
    return packed_content(entry, data)


def source_entries(
    bundle: Path,
    header: dict[str, Any],
    data: bytes,
) -> Iterator[tuple[str, dict[str, Any], bytes]]:
    for path, entry in walk_entries(header["files"]):
        if Path(path).suffix.lower() not in TEXT_SUFFIXES:
            continue
        try:
            size = int(entry.get("size", 0))
        except (TypeError, ValueError):
            continue
        if size <= 0 or size > MAX_SOURCE_SIZE:
            continue
        yield path, entry, entry_content(bundle, path, entry, data)


def discover_upstream_target(
    bundle: Path,
    header: dict[str, Any],
    data: bytes,
) -> tuple[str, dict[str, Any], bytes]:
    candidates: list[tuple[str, dict[str, Any], bytes, int]] = []
    total_matches = 0
    for path, entry, source in source_entries(bundle, header, data):
        count = len(TITLEBAR_PATTERN.findall(source))
        if not count:
            continue
        total_matches += count
        candidates.append((path, entry, source, count))

    if total_matches != 1 or len(candidates) != 1:
        summary = [{"path": path, "matches": count} for path, _, _, count in candidates]
        raise ValueError(
            "Claude main-window titlebar pattern matched "
            f"{total_matches} times across {len(candidates)} files; expected 1: "
            f"{json.dumps(summary, sort_keys=True)}"
        )
    path, entry, source, _count = candidates[0]
    return path, entry, source


def discover_patched_target(
    bundle: Path,
    header: dict[str, Any],
    data: bytes,
) -> tuple[str, dict[str, Any], bytes]:
    marker = PATCH_MARKER.encode("ascii")
    candidates: list[tuple[str, dict[str, Any], bytes, int]] = []
    marker_count = 0
    upstream_count = 0
    for path, entry, source in source_entries(bundle, header, data):
        count = source.count(marker)
        upstream_count += len(TITLEBAR_PATTERN.findall(source))
        if not count:
            continue
        marker_count += count
        candidates.append((path, entry, source, count))

    if marker_count != 1 or len(candidates) != 1:
        summary = [{"path": path, "markers": count} for path, _, _, count in candidates]
        raise ValueError(
            f"Claude titlebar patch marker count is {marker_count}; expected 1: "
            f"{json.dumps(summary, sort_keys=True)}"
        )
    if upstream_count:
        raise ValueError(
            f"Claude titlebar bundle still contains {upstream_count} upstream pattern(s)"
        )
    path, entry, source, _count = candidates[0]
    return path, entry, source


def update_integrity(entry: dict[str, Any], content: bytes) -> None:
    integrity = entry.get("integrity")
    if not isinstance(integrity, dict):
        return
    algorithm = str(integrity.get("algorithm", "SHA256")).upper()
    if algorithm != "SHA256":
        raise ValueError(f"Unsupported ASAR integrity algorithm: {algorithm}")
    block_size = int(integrity.get("blockSize", 4 * 1024 * 1024))
    if block_size <= 0:
        raise ValueError(f"Invalid ASAR integrity block size: {block_size}")
    integrity["algorithm"] = "SHA256"
    integrity["hash"] = hashlib.sha256(content).hexdigest()
    integrity["blockSize"] = block_size
    integrity["blocks"] = [
        hashlib.sha256(content[offset : offset + block_size]).hexdigest()
        for offset in range(0, len(content), block_size)
    ]


def patch_source(source: bytes) -> bytes:
    marker = PATCH_MARKER.encode("ascii")
    if marker in source:
        if TITLEBAR_PATTERN.search(source):
            raise ValueError("Claude titlebar marker exists beside unpatched source")
        return source

    matches = list(TITLEBAR_PATTERN.finditer(source))
    if len(matches) != 1:
        raise ValueError(
            f"Claude main-window titlebar pattern matched {len(matches)} times; expected 1"
        )
    overlay_alias = matches[0].group(1)
    replacement = (
        b'titleBarStyle:process.platform==="linux"?"default":"hidden",'
        b'titleBarOverlay:process.platform==="linux"?!1:'
        + overlay_alias
        + b"/*"
        + marker
        + b"*/"
    )
    return source[: matches[0].start()] + replacement + source[matches[0].end() :]


def find_bundle() -> Path:
    roots = (Path("/usr/lib/claude-desktop"), Path("/opt/claude-desktop"))
    bundles = sorted(
        bundle
        for root in roots
        if root.exists()
        for bundle in root.rglob("app.asar")
    )
    if len(bundles) != 1:
        raise ValueError(f"Expected one Claude app.asar, found {len(bundles)}: {bundles}")
    return bundles[0]


def verify(bundle: Path) -> dict[str, Any]:
    header, data = read_asar(bundle)
    path, entry, source = discover_patched_target(bundle, header, data)
    if not entry.get("unpacked"):
        raise ValueError("Claude titlebar target is not marked unpacked")
    if b'process.platform==="linux"?"default":"hidden"' not in source:
        raise ValueError("Claude Linux titleBarStyle native branch is missing")
    if b'process.platform==="linux"?!1:' not in source:
        raise ValueError("Claude Linux titleBarOverlay disable branch is missing")

    size = int(entry.get("size", -1))
    if size != len(source):
        raise ValueError(f"Claude unpacked target size mismatch: {size} != {len(source)}")
    integrity = entry.get("integrity")
    if isinstance(integrity, dict):
        expected = hashlib.sha256(source).hexdigest()
        if integrity.get("hash") != expected:
            raise ValueError("Claude unpacked target integrity hash is stale")

    return {
        "bundle": str(bundle),
        "target": path,
        "marker": PATCH_MARKER,
        "sha256": hashlib.sha256(source).hexdigest(),
        "size": len(source),
        "mode": "x11-native-titlebar",
        "packedDataBytesRetained": len(data),
    }


def preserve_ownership(path: Path, source_stat: os.stat_result) -> None:
    current = path.stat()
    if (current.st_uid, current.st_gid) == (source_stat.st_uid, source_stat.st_gid):
        return
    if os.geteuid() != 0:
        raise PermissionError(
            f"Cannot preserve ownership for {path}: "
            f"{current.st_uid}:{current.st_gid} != "
            f"{source_stat.st_uid}:{source_stat.st_gid}"
        )
    os.chown(path, source_stat.st_uid, source_stat.st_gid)


def patch(bundle: Path, report_path: Path) -> dict[str, Any]:
    header, data = read_asar(bundle)
    path, entry, source = discover_upstream_target(bundle, header, data)
    target = unpacked_target(bundle, path)
    patched = patch_source(source)

    target.parent.mkdir(parents=True, exist_ok=True)
    temporary_target = target.with_name(f".{target.name}.grotto-tmp")
    temporary_target.write_bytes(patched)
    os.chmod(temporary_target, 0o644)
    os.replace(temporary_target, target)

    entry["size"] = len(patched)
    entry["unpacked"] = True
    entry.pop("offset", None)
    update_integrity(entry, patched)

    encoded_header = encode_header(header)
    original_stat = bundle.stat()
    with tempfile.NamedTemporaryFile(
        mode="wb",
        dir=bundle.parent,
        prefix=f".{bundle.name}.grotto-",
        delete=False,
    ) as handle:
        temporary_bundle = Path(handle.name)
        handle.write(encoded_header)
        handle.write(data)
        handle.flush()
        os.fsync(handle.fileno())
    os.chmod(temporary_bundle, stat.S_IMODE(original_stat.st_mode))
    preserve_ownership(temporary_bundle, original_stat)
    os.replace(temporary_bundle, bundle)

    report = verify(bundle)
    report_path.parent.mkdir(parents=True, exist_ok=True)
    report_path.write_text(json.dumps(report, indent=2) + "\n", encoding="utf-8")
    return report


def self_test() -> None:
    fixture = (
        b'const x={titleBarStyle:"hidden",titleBarOverlay:vo,'
        b'webPreferences:{preload:"main.js"}};'
    )
    patched = patch_source(fixture)
    assert PATCH_MARKER.encode() in patched
    assert b'titleBarStyle:process.platform==="linux"?"default":"hidden"' in patched
    assert b'titleBarOverlay:process.platform==="linux"?!1:vo' in patched
    assert patch_source(patched) == patched

    target_path = ".vite/build/index.chunk-test.js"
    header = {
        "files": {
            ".vite": {
                "files": {
                    "build": {
                        "files": {
                            "index.js": {
                                "size": 20,
                                "offset": str(len(fixture)),
                            },
                            "index.chunk-test.js": {
                                "size": len(fixture),
                                "offset": "0",
                            },
                        }
                    }
                }
            }
        }
    }
    with tempfile.TemporaryDirectory() as temporary_directory:
        bundle = Path(temporary_directory) / "app.asar"
        bundle.write_bytes(encode_header(header) + fixture + b"export{main as default}")
        report_path = Path(temporary_directory) / "report.json"
        report = patch(bundle, report_path)
        assert report["target"] == target_path
        assert verify(bundle)["marker"] == PATCH_MARKER


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--bundle", type=Path)
    parser.add_argument("--report", type=Path, default=DEFAULT_REPORT_PATH)
    parser.add_argument("--verify", action="store_true")
    parser.add_argument("--self-test", action="store_true")
    arguments = parser.parse_args()

    if arguments.self_test:
        self_test()
        print("Claude titlebar patch self-test passed")
        return 0

    bundle = arguments.bundle or find_bundle()
    report = verify(bundle) if arguments.verify else patch(bundle, arguments.report)
    print(json.dumps(report, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
