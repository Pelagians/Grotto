[Desktop Entry]
Type=Application
Name=Grotto Selkies viewer browser bridge
Comment=Open Claude authentication links in the browser viewing this Selkies session
Exec=/usr/local/bin/grotto-claude-browser %u
Terminal=false
NoDisplay=true
MimeType=text/html;x-scheme-handler/http;x-scheme-handler/https;
Categories=Network;WebBrowser;
