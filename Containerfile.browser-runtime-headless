# syntax=docker/dockerfile:1.7
ARG PLAYWRIGHT_VERSION=1.60.0
FROM mcr.microsoft.com/playwright:v${PLAYWRIGHT_VERSION}-noble

ARG PLAYWRIGHT_VERSION=1.60.0
ARG OPENQUAD_IMAGE_NAME="openquad-browser-runtime-headless"

USER root
ENV OPENQUAD_IMAGE_NAME=${OPENQUAD_IMAGE_NAME} \
    OPENQUAD_RUNTIME=browser-runtime-headless \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 \
    PLAYWRIGHT_WS_HOST=0.0.0.0 \
    PLAYWRIGHT_WS_PORT=3000 \
    PLAYWRIGHT_HEADLESS=true \
    BROWSER_DOWNLOAD_DIR=/home/pwuser/downloads \
    BROWSER_ARTIFACTS_DIR=/home/pwuser/artifacts

WORKDIR /opt/openquad/browser-runtime
RUN set -eux; \
    npm init -y; \
    npm install --omit=dev "playwright@${PLAYWRIGHT_VERSION}"; \
    npm cache clean --force; \
    install -d -o pwuser -g pwuser /home/pwuser/downloads /home/pwuser/artifacts; \
    chown -R pwuser:pwuser /opt/openquad/browser-runtime /home/pwuser

COPY runtimes/browser/headless/launch-server.js /opt/openquad/browser-runtime/headless/launch-server.js
COPY runtimes/browser/shared/launch-options.js /opt/openquad/browser-runtime/shared/launch-options.js
COPY templates/browser-runtime-headless/Brewfile /usr/share/openquad/templates/browser-runtime-headless/Brewfile
RUN set -eux; \
    chown -R pwuser:pwuser /opt/openquad/browser-runtime/headless /opt/openquad/browser-runtime/shared; \
    test -r /usr/share/openquad/templates/browser-runtime-headless/Brewfile

EXPOSE 3000
USER pwuser
WORKDIR /opt/openquad/browser-runtime
CMD ["node", "/opt/openquad/browser-runtime/headless/launch-server.js"]
